<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="35.0" prefWidth="835.0" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="/styles-css/Titlebar styles.css"
            fx:controller="com.mastertyres.components.fxComponents.tittleBar.TitleBarController">

    <StackPane fx:id="tittleBarModal" style="-fx-background-color: #080808;"
                AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <HBox alignment="CENTER_RIGHT" spacing="0">

            <!-- Cerrar -->
            <StackPane fx:id="btnCerrar" onMouseClicked="#cerrar" style="-fx-padding: 8 14 8 14;"
                       styleClass="title-bar-btn title-bar-btn-close">

                <ImageView fitHeight="12.0" fitWidth="12.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/icons/ventana_principal/exit.png"/>
                    </image>
                </ImageView>
            </StackPane>

        </HBox>
    </StackPane>

</AnchorPane>
