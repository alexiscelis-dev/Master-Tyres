<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="tittleBar" prefHeight="35.0" style="-fx-background-color: #080808;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.components.fxComponents.tittleBar.TitleBarController">

    <HBox alignment="CENTER_RIGHT" spacing="0"
          AnchorPane.rightAnchor="0.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0">

        <StackPane fx:id="btnMinimizar" onMouseClicked="#minimizar"
                   prefWidth="46.0" prefHeight="35.0"
                   minWidth="46.0" minHeight="35.0">  <!-- ← Valores fijos -->
            <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                <Image url="/icons/minimizar.png"/>
            </ImageView>
        </StackPane>

        <!-- Maximizar -->
        <StackPane fx:id="btnMaximizar"
                   onMouseClicked="#maximizarRestaurar">
            <ImageView fx:id="iconoMaximizar" fitHeight="20.0" fitWidth="20.0"
                       pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@/icons/ventana_principal/restaurar.png"/>
                </image>
            </ImageView>
        </StackPane>

        <StackPane fx:id="btnCerrar" onMouseClicked="#cerrar"
                   prefWidth="46.0" prefHeight="35.0"
                   minWidth="46.0" minHeight="35.0">  <!-- ← Valores fijos -->
            <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                <Image url="/icons/ventana_principal/exit.png"/>
            </ImageView>
        </StackPane>

    </HBox>
</AnchorPane>