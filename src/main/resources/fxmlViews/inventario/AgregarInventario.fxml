<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="800.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.inventario.AgregarInventarioController">
    <children>

        <VBox layoutX="320.0" layoutY="150.0" prefHeight="620.0" prefWidth="600.0" style="-fx-background-color: #1A1A1A;" styleClass="formulario" stylesheets="@../../styles_css/Inventario.css">

            <children>


                <HBox alignment="CENTER" prefHeight="33.0" prefWidth="460.0">
                    <children>
                        <Label alignment="TOP_CENTER" prefHeight="30.0" prefWidth="272.0" styleClass="seccion-titulo" text="Agregar Llanta" textFill="WHITE" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="30.0" />
                    </VBox.margin>
                </HBox>

                <GridPane alignment="CENTER" hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints fillWidth="false" halignment="CENTER" hgrow="ALWAYS" prefWidth="110.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints fillWidth="false" halignment="CENTER" hgrow="SOMETIMES" prefWidth="80" />


                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints fillHeight="false" prefHeight="35.0" valignment="CENTER" vgrow="SOMETIMES" />
                        <RowConstraints prefHeight="35.0" />
                        <RowConstraints prefHeight="35.0" />
                        <RowConstraints fillHeight="false" prefHeight="50.0" valignment="CENTER" vgrow="NEVER" />
                        <RowConstraints prefHeight="35.0" />
                        <RowConstraints fillHeight="false" prefHeight="35.0" valignment="CENTER" />
                        <RowConstraints />

                    </rowConstraints>

                    <children>

                        <Label style="-fx-pref-width: 80;" styleClass="label-formulario" text="Marca *" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <GridPane.margin>
                                <Insets left="10.0" />
                            </GridPane.margin>
                        </Label>

                        <TextField fx:id="txtMarca" styleClass="buscador-marca" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="0" />

                        <Label style="-fx-pref-width: 80;" styleClass="label-formulario" text="Modelo *" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <GridPane.margin>
                                <Insets left="10.0" />
                            </GridPane.margin>
                        </Label>

                        <TextField fx:id="txtModelo" styleClass="buscador-marca" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="1" />

                        <Label style="-fx-pref-width: 80;" styleClass="label-formulario" text="Medida *" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <GridPane.margin>
                                <Insets left="10.0" />
                            </GridPane.margin>
                        </Label>

                        <HBox alignment="CENTER" spacing="10" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="2">
                            <ChoiceBox fx:id="choiceAncho" prefWidth="150.0" styleClass="choicebox-mini3">

                            </ChoiceBox>
                            <Label text="/">
                                <font>
                                    <Font size="18.0" />
                                </font>
                            </Label>

                            <ChoiceBox fx:id="choicePerfil" prefWidth="150.0" styleClass="choicebox-mini3">

                            </ChoiceBox>

                            <Label text="R">

                            </Label>

                            <ChoiceBox fx:id="choiceRin" prefWidth="150.0" styleClass="choicebox-mini3">

                            </ChoiceBox>

                        </HBox>


                        <Label alignment="CENTER" style="-fx-pref-width: 165;" text="Indice carga *" GridPane.columnIndex="0" GridPane.rowIndex="3">

                        </Label>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="3">
                            <ChoiceBox fx:id="cbIndiceCarga" prefWidth="150.0" styleClass="choicebox-mini3">


                                <opaqueInsets>
                                    <Insets />
                                </opaqueInsets>
                                <HBox.margin>
                                    <Insets right="20.0" />
                                </HBox.margin>
                            </ChoiceBox>

                            <Label prefHeight="18.0" prefWidth="61.0" style="-fx-pref-width: 125;" text="Indice de velocidad *">
                                <opaqueInsets>
                                    <Insets />
                                </opaqueInsets>
                                <HBox.margin>
                                    <Insets right="1.0" top="5.0" />
                                </HBox.margin>
                            </Label>
                            <ChoiceBox fx:id="cbIndiceVelocidad" prefWidth="150.0" styleClass="choicebox-mini3">
                                <HBox.margin>
                                    <Insets />
                                </HBox.margin>
                            </ChoiceBox>

                        </HBox>

                        <Label styleClass="label-formulario" text="Precio de compra *" GridPane.columnIndex="0" GridPane.rowIndex="4">
                            <opaqueInsets>
                                <Insets />
                            </opaqueInsets>
                            <HBox.margin>
                                <Insets left="20.0" right="15.0" />
                            </HBox.margin>
                        </Label>

                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="4">

                            <TextField fx:id="txtPrecioC" styleClass="buscador-medida">

                            </TextField>

                            <Label styleClass="label-formulario" text="Precio de venta *">
                                <HBox.margin>
                                    <Insets right="15.0" />
                                </HBox.margin>
                            </Label>
                            <TextField fx:id="txtPrecioV" styleClass="buscador-medida" />

                        </HBox>


                        <Label style="-fx-pref-width: 80;" text="Stock *" GridPane.columnIndex="0" GridPane.rowIndex="5">
                            <opaqueInsets>
                                <Insets />
                            </opaqueInsets>
                            <HBox.margin>
                                <Insets left="20.0" right="15.0" />
                            </HBox.margin>
                        </Label>
                        <TextField fx:id="txtStock" prefWidth="400" styleClass="buscador-medida" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="5" />


                        <Label style="-fx-pref-width: 60;" styleClass="label-codigo" text="Dot" GridPane.columnIndex="0" GridPane.rowIndex="6">

                        </Label>


                        <HBox spacing="10" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="6">

                            <TextField fx:id="txtDot" styleClass="buscador-codigo" />


                            <Label style="-fx-pref-width: 155;" text="Codigo de barras ">
                            </Label>

                            <TextField fx:id="txtCodBarras" styleClass="buscador-codigo">

                            </TextField>


                        </HBox>


                    </children>

                </GridPane>


                <HBox alignment="CENTER_LEFT" prefHeight="30.0" prefWidth="200.0">
                    <children>


                    </children>
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                </HBox>


                <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="label-formulario" text="Observaciones">
                            <HBox.margin>
                                <Insets left="20.0" />
                            </HBox.margin>
                        </Label>
                        <TextField fx:id="txtObservaciones" prefHeight="45" promptText="Características, observaciones etc..." styleClass="buscador-observaciones" HBox.hgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                </HBox>


                <HBox alignment="CENTER" prefHeight="30.0" prefWidth="560.0">
                    <children>
                        <TextField fx:id="txtImg" disable="false" prefHeight="26.0" prefWidth="204.0" promptText="Seleccionar imagen (Opcional)" styleClass="buscador-img" />

                        <Button fx:id="btnImagen" mnemonicParsing="false" prefHeight="17.0" prefWidth="28.0" styleClass="boton-img" text="..." />
                    </children>
                    <opaqueInsets>
                        <Insets />
                    </opaqueInsets>
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </HBox>

                <HBox alignment="CENTER" prefHeight="91.0" prefWidth="560.0">
                    <children>
                        <Button fx:id="btnRegistrar" contentDisplay="CENTER" mnemonicParsing="false" styleClass="boton-accion" text="Registrar">
                            <HBox.margin>
                                <Insets right="15.0" />
                            </HBox.margin>
                        </Button>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" styleClass="boton-accion" text="Limpiar">
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </Button>
                    </children>


                </HBox>


            </children>


        </VBox>


    </children>


</AnchorPane>
