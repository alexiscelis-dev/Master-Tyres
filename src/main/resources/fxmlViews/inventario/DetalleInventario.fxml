<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.inventario.DetalleInventarioController">



    <children>

        <ScrollPane fx:id="scrollPane" style="-fx-background-color: #080808;">
        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label text="Informacion del inventario" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="40.0" />
                </font>
            </Label>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="LEFT" prefWidth="600.0" />
                </columnConstraints>

                <!-- codigo de barras -->
                <Label fx:id="lblCodBarras" text="Codigo de barras:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Primer Apellido -->
                <Label fx:id="lblDot" text="Dot:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Segundo Apellido -->
                <Label fx:id="lblMarca" text="Marca:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Modelo -->
                <Label fx:id="lblModelo" text="Modelo:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Medida -->
                <Label fx:id="lblMedida" text="Medida:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Indice carga -->
                <Label fx:id="lblIdCarga" text="Indice de carga:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="5">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Indice velocidad -->
                <Label fx:id="lblIdVelocidad" text="Indice de velocidad:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- stock -->
                <Label fx:id="lblStock" text="Stock:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="7">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Precio compra -->
                <Label fx:id="lblPrecioC" text="Precio de compra:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="8">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Precio de venta  -->
                <Label fx:id="lblPrecioV" text="Precio de venta:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="9">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Tipo Cliente -->
                <Label fx:id="lblObservaciones" text="Observaciones:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="10">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- fecha de registro -->
                <Label fx:id="lblFechaRegistro" text="Fecha de registro:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="11">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints minHeight="10.0" prefHeight="30.0" />
                </rowConstraints>
            </GridPane>

            <ImageView fx:id="imgInventario" fitHeight="300" fitWidth="300" smooth="true" styleClass="detalle-img">

            </ImageView>

            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#cerrarVentana" fx:id="btnCerrar" styleClass="boton-accion" text="Cerrar" />
            </HBox>
        </VBox>

        </ScrollPane>
    </children>
</AnchorPane>
