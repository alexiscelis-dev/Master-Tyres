<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/InventarioStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.controllers.fxControllers.inventario.DetalleInventarioController">



    <children>

        <ScrollPane fx:id="scrollPane" style="-fx-background-color: #080808;">
            <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label styleClass="s" text="Informacion del inventario" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="40.0" />
                    </font>
                </Label>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" prefWidth="600.0" />
                    </columnConstraints>

                    <!-- codigo de barras -->
                    <Label styleClass="s" fx:id="txtCodBarras" text="Codigo de barras:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Primer Apellido -->
                    <Label styleClass="s" fx:id="txtDot" text="Dot:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Segundo Apellido -->
                    <Label styleClass="s" fx:id="txtMarca" text="Marca:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Modelo -->
                    <Label styleClass="s" fx:id="txtModelo" text="Modelo:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Medida -->
                    <Label styleClass="s" fx:id="txtMedida" text="Medida:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Indice carga -->
                    <Label  styleClass="s" fx:id="txtIdCarga" text="Indice de carga:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="5">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Indice velocidad -->
                    <Label styleClass="s" fx:id="txtIdVelocidad" text="Indice de velocidad:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="6">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- stock -->
                    <Label styleClass="s" fx:id="txtStock" text="Stock:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="7">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Precio compra -->
                    <Label styleClass="s" fx:id="txtPrecioC" text="Precio de compra:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="8">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Precio de venta  -->
                    <Label styleClass="s" fx:id="txtPrecioV" text="Precio de venta:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="9">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Tipo Cliente -->
                    <Label styleClass="s" fx:id="txtObservaciones" text="Observaciones:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="10">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- fecha de registro -->
                    <Label styleClass="s" fx:id="txtFechaRegistro" text="Fecha de registro:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="11">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                    </rowConstraints>
                </GridPane>

                <StackPane alignment="CENTER" prefHeight="300.0" prefWidth="300.0" styleClass="detalle-img-frame">
                    <ImageView fx:id="imgInventario" fitHeight="300" fitWidth="300" pickOnBounds="true" preserveRatio="true" smooth="true" styleClass="detalle-img" />
                </StackPane>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnCerrar" styleClass="boton-accion" text="Cerrar" />
                </HBox>
            </VBox>

        </ScrollPane>
    </children>
</AnchorPane>
