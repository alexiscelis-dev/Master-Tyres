<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="383.0" prefWidth="835.0" styleClass="root" stylesheets="/styles_css/stylesLogin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.login.LoginController">

    <StackPane fx:id="Panel" layoutX="49.0" prefHeight="383.0" prefWidth="926.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="49.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <HBox alignment="CENTER" spacing="0">

            <!-- Login Form -->
            <VBox alignment="CENTER" maxHeight="500" maxWidth="451.0" prefHeight="383.0" prefWidth="451.0" spacing="20" styleClass="login-container">
                <Label styleClass="title" text="Login" />
                <TextField fx:id="usernameField" promptText="Username" styleClass="input-field" />
                <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field" />
                <Button fx:id="loginButton" prefHeight="26.0" prefWidth="451.0" styleClass="login-button" text="Iniciar sesión." onAction="#logIn" />
                <Hyperlink fx:id="forgotPassword" styleClass="forgot-link" text="¿Se te olvidó la contraseña?" />
                <Label fx:id="errorLabel" styleClass="error-label" text="" visible="false" />
            </VBox>

            <!-- Contenedor del logo con fondo -->
            <StackPane maxHeight="500" maxWidth="451.0" prefHeight="383.0" prefWidth="451.0" style="-fx-background-color: #FFFFFF;  -fx-padding: 20; -fx-background-radius: 10;">
                <ImageView fx:id="logoImage" fitHeight="200" preserveRatio="true">
                    <image>
                        <Image url="@../icons/Master Tyres Logo.png" />
                    </image></ImageView>
            </StackPane>

        </HBox>
    </StackPane>

    <HBox AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0"
          style="-fx-background-color: #8EB83D;" alignment="CENTER">
        <Label fx:id="footerLabel" text="© 2025 Master Tyres. Todos los derechos reservados."
               style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; "
               AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
               alignment="CENTER" />
    </HBox>
</AnchorPane>
