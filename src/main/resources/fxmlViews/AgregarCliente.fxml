<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="ventanaAgregarCliente" prefHeight="600.0" prefWidth="1344.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.agregarCliente.AgregarClienteController">
   <AnchorPane layoutY="110.0" prefHeight="696.0" prefWidth="1186.0">
      <children>

          <!-- ScrollPane que contiene ambas secciones -->
          <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #080808;" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
              <HBox fx:id="contenedorPrincipal" spacing="20.0" style="-fx-background-color: #080808;">
                  <padding>
                      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>

                  <!-- Sección Izquierda: Datos del Cliente -->
                  <VBox alignment="TOP_CENTER" prefWidth="600.0" spacing="15.0" styleClass="secciones">
                      <Label styleClass="seccion-titulo" text="Datos del Cliente:" />
                      <GridPane hgap="10" vgap="10">
                          <columnConstraints>
                              <ColumnConstraints percentWidth="33" />
                              <ColumnConstraints percentWidth="33" />
                              <ColumnConstraints percentWidth="33" />
                          </columnConstraints>

                          <Label text="*Tipo de cliente:" />
                          <ChoiceBox fx:id="choiceTipoCliente" prefHeight="26.0" prefWidth="151.0" style="-fx-text-alignment: right;" styleClass="choicebox-mini" GridPane.columnIndex="1">

                              <items>
                                  <FXCollections fx:factory="observableArrayList">
                                      <String fx:value="Individual" />
                                      <String fx:value="Empresa" />
                                  </FXCollections>
                              </items>
                          </ChoiceBox>

                          <Label text="Genero: " GridPane.rowIndex="1" />
                          <ChoiceBox fx:id="choiceGenero" prefHeight="26.0" prefWidth="151.0" style="-fx-text-alignment: right;" styleClass="choicebox-mini"  GridPane.columnIndex="1" GridPane.rowIndex="1">
                              <items>
                                  <FXCollections fx:factory="observableArrayList">
                                      <String fx:value="Masculino" />
                                      <String fx:value="Femenino" />
                                      <String fx:value="Otro" />
                                  </FXCollections>
                            </items>
                          </ChoiceBox>
                          <DatePicker fx:id="pickerCumpleanos" promptText="Cumpleaños" styleClass="date-picker" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                          <TextField fx:id="txtNombre" promptText="*Nombre" styleClass="buscador" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                          <TextField fx:id="txtApellido" promptText="*Primer Apellido" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                          <TextField fx:id="txtSegundoApellido" promptText="Segundo Apellido" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                          <TextField fx:id="txtDomicilio" promptText="Domicilio" styleClass="buscador" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="3" />

                          <TextField fx:id="txtCiudad" promptText="Ciudad" styleClass="buscador" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                          <TextField fx:id="txtEstado" promptText="Estado" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="4" />

                          <TextField fx:id="txtTelefono" promptText="*Teléfono" styleClass="buscador" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                          <TextField fx:id="txtRFC" promptText="RFC" styleClass="buscador" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="5" />

                          <TextField fx:id="txtHobbie" promptText="Hobbie" styleClass="buscador" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="6" />

                     <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" />
                        <RowConstraints />
                     </rowConstraints>
                      </GridPane>
                  </VBox>
      
                  <!-- Sección Derecha: Datos del Vehículo -->
                  <VBox alignment="TOP_CENTER" prefWidth="600.0" spacing="15.0" styleClass="secciones">
                      <Label styleClass="seccion-titulo" text="Datos del Vehículo" />
                      <GridPane hgap="10" vgap="10">
                          <columnConstraints>
                              <ColumnConstraints percentWidth="33" />
                              <ColumnConstraints percentWidth="33" />
                              <ColumnConstraints percentWidth="33" />
                          </columnConstraints>

                          <!-- Fila 0 -->
                          <Label text="Marca:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                          <ChoiceBox fx:id="choiceMarca" styleClass="choicebox-mini2" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                          <TextField fx:id="txtSerie" promptText="Número de Serie" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                          <!-- Fila 1 -->
                          <Label text="Modelo:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                          <ChoiceBox fx:id="choiceModelo" styleClass="choicebox-mini2" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                          <TextField fx:id="txtColor" promptText="Color" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                          <!-- Fila 2 -->
                          <Label text="Categoría:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                          <ChoiceBox fx:id="choiceCategoria" styleClass="choicebox-mini2" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                          <TextField fx:id="txtPlacas" promptText="Placas" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                          <!-- Fila 3 -->
                          <Label text="Año:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                          <Spinner fx:id="spinnerAnio" editable="true" promptText="Año" styleClass="spinner" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                          <TextField fx:id="txtKilometros" promptText="Kilómetros" styleClass="buscador" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                          <!-- Fila 4 -->
                          <Label text="Último Servicio:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                          <DatePicker fx:id="pickerUltimoServicio" promptText="Último Servicio" styleClass="date-picker" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="4" />

                          <!-- Fila 5 -->
                          <TextField fx:id="txtObservaciones" prefHeight="60.0" promptText="Observaciones" styleClass="buscador" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="5" />

                          <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                          </rowConstraints>
                      </GridPane>


                      <Button fx:id="btnAgregarVehiculo" alignment="CENTER" contentDisplay="CENTER" onAction="#agregarVehiculo" styleClass="boton-accion" text="Agregar Vehículo" textAlignment="CENTER" />

                      <TableView fx:id="tablaVehiculos" editable="true" minHeight="150" prefHeight="150">
                          <columns>
                              <TableColumn fx:id="colMarca" text="Marca" />
                              <TableColumn fx:id="colModelo" text="Modelo" />
                              <TableColumn fx:id="colAnnio" text="Año" />
                              <TableColumn fx:id="colCategoria" text="Categoria" />
                              <TableColumn fx:id="colColor" text="Color" />
                              <TableColumn fx:id="colPlacas" text="Placas" />
                              <TableColumn fx:id="colNumSerie" text="Numero de serie" />
                              <TableColumn fx:id="colKilometros" text="Kilometros" />
                              <TableColumn fx:id="colultimoServicio" text="Ultimo Servicio" />
                              <TableColumn fx:id="colObservaciones" text="Observaciones" />
                              <TableColumn fx:id="colEliminar" style="-fx-alignment: CENTER;" text="Acción" />
                          </columns>
                      </TableView>
                  </VBox>
              </HBox>
          </ScrollPane>
      
          <!-- Botones centrados abajo -->
          <HBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
              <Button fx:id="btnGuardar" onAction="#GuardarCliente" styleClass="boton-accion" text="Guardar" />
              <Button fx:id="btnCancelar" styleClass="boton-accion" text="Cancelar" />
          </HBox>
      </children>
   </AnchorPane>
</AnchorPane>
