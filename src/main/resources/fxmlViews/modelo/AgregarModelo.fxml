<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.AdministrarMarcasModelosCategorias.AgregarModeloController">

    <children>
        <HBox alignment="TOP_CENTER" spacing="20">

            <!-- VEHÍCULOS PARTICIPANTES -->
            <VBox alignment="CENTER" minWidth="400.0" prefHeight="500.0" prefWidth="600.0" spacing="15.0" styleClass="secciones">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label styleClass="seccion-titulo" text="AGREGAR MODELO">
               <font>
                  <Font size="24.0" />
               </font></Label>

                <HBox alignment="TOP_CENTER" spacing="5">
                    <TextField fx:id="txtModelo" prefWidth="160.0" promptText="Modelo" styleClass="buscador" />
                    <Label text="   Categoria:    " />
                    <ChoiceBox fx:id="choiceCategoria" prefWidth="160.0" styleClass="choicebox-mini2" />
                </HBox>

                <!-- Botón Agregar -->
                <Button fx:id="btnAgregarVehiculo" onAction="#agregarVehiculo" styleClass="boton-accion" text="Agregar Modelo" />

                <!-- Tabla -->
                <TableView fx:id="tablaVehiculos" maxWidth="385.0" prefHeight="222.0" prefWidth="385.0">
                    <columns>
                        <TableColumn fx:id="colModelo" prefWidth="140.0" text="Modelo" />
                        <TableColumn fx:id="colCategoria" prefWidth="140.0" text="Categoria" />
                        <TableColumn fx:id="colEliminar" prefWidth="51.0" style="-fx-alignment:CENTER;" text="Eliminar" />
                    </columns>
                </TableView>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                       <Button fx:id="btnGuardar" onAction="#GuardarCambios" styleClass="boton-accion" text="Guardar">
                     <HBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </HBox.margin></Button>
                       <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cancelar">
                     <HBox.margin>
                        <Insets left="10.0" right="10.0" />
                     </HBox.margin></Button>
               </children>
            </HBox>
            </VBox>

        </HBox>

    </children>
</AnchorPane>
