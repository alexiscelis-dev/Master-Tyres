<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<AnchorPane fx:id="rootPane"
            prefHeight="500"
            prefWidth="600"
            style="-fx-background-color: #080808;"
            stylesheets="/styles-css/ClientesStyles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.AdministrarMarcasModelosCategorias.AgregarModeloController">

    <children>

        <!-- TitleBar -->
        <fx:include source="/fxmlComponentes/Components/TitleBar/modalTittleBar/TittleBarModalComponent.fxml"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"/>

        <!-- Contenido -->
        <HBox alignment="TOP_CENTER"
              spacing="20"
              AnchorPane.topAnchor="40.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0">

            <VBox alignment="CENTER"
                  minWidth="400.0"
                  prefWidth="600.0"
                  spacing="15.0"
                  styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20"/>
                </padding>

                <Label styleClass="seccion-titulo" text="AGREGAR MODELO">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>

                <HBox alignment="TOP_CENTER" spacing="5">
                    <TextField fx:id="txtModelo"
                               prefWidth="160.0"
                               promptText="Modelo"
                               styleClass="buscador"/>

                    <Label text="   Categoria:    "/>

                    <ChoiceBox fx:id="choiceCategoria"
                               prefWidth="160.0"
                               styleClass="choicebox-mini2"/>
                </HBox>

                <!-- Botón Agregar -->
                <Button fx:id="btnAgregarVehiculo"
                        onAction="#agregarVehiculo"
                        styleClass="boton-accion"
                        text="Agregar Modelo"/>

                <!-- Tabla -->
                <TableView fx:id="tablaVehiculos"
                           maxWidth="385.0"
                           prefHeight="222.0"
                           prefWidth="385.0">

                    <columns>
                        <TableColumn fx:id="colModelo" prefWidth="140.0" text="Modelo"/>
                        <TableColumn fx:id="colCategoria" prefWidth="140.0" text="Categoria"/>
                        <TableColumn fx:id="colEliminar" prefWidth="51.0"
                                     style="-fx-alignment:CENTER;"
                                     text="Eliminar"/>
                    </columns>

                </TableView>

                <HBox alignment="CENTER">
                    <Button fx:id="btnGuardar"
                            onAction="#GuardarCambios"
                            styleClass="boton-accion"
                            text="Guardar">
                        <HBox.margin>
                            <Insets left="10.0" right="10.0"/>
                        </HBox.margin>
                    </Button>

                    <Button onAction="#cerrarVentana"
                            styleClass="boton-accion"
                            text="Cancelar">
                        <HBox.margin>
                            <Insets left="10.0" right="10.0"/>
                        </HBox.margin>
                    </Button>
                </HBox>

            </VBox>

        </HBox>

    </children>
</AnchorPane>