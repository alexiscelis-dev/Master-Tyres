<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane fx:id="rootPane"
            prefHeight="190.0"
            prefWidth="600"
            style="-fx-background-color: #080808;"
            stylesheets="/styles-css/ClientesStyles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.AdministrarMarcasModelosCategorias.EditarModeloController">

    <children>

        <!-- TitleBar -->
        <fx:include source="/fxmlComponentes/Components/TitleBar/modalTittleBar/TittleBarModalComponent.fxml"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"/>

        <!-- Contenido -->
        <HBox alignment="TOP_CENTER"
              spacing="20"
              AnchorPane.topAnchor="40.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0">

            <VBox alignment="CENTER"
                  prefWidth="600"
                  spacing="10"
                  styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20"/>
                </padding>

                <Label styleClass="seccion-titulo" text="Editar Modelo"/>

                <GridPane hgap="10" vgap="10">

                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="150"/>
                        <ColumnConstraints prefWidth="350.0"/>
                    </columnConstraints>

                    <!-- Nombre -->
                    <Label text="Nombre del Modelo:"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="0"/>

                    <TextField fx:id="txtModelo"
                               promptText="Nombre del modelo"
                               styleClass="buscador"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>

                    <!-- Categoria -->
                    <Label text="Categoria:"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="1"/>

                    <ChoiceBox fx:id="choiceCategoria"
                               prefHeight="26.0"
                               prefWidth="350.0"
                               styleClass="choicebox-mini2"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>

                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>

                </GridPane>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">

                    <Button fx:id="btnGuardar"
                            onAction="#GuardarCambios"
                            styleClass="boton-accion"
                            text="Actualizar"/>

                    <Button onAction="#cerrarVentana"
                            styleClass="boton-accion"
                            text="Cancelar"/>

                </HBox>

            </VBox>

        </HBox>

    </children>
</AnchorPane>