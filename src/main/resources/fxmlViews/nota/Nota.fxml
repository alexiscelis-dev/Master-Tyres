                                <Label text="Fecha limite:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="6">

                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <Label fx:id="lblFechaLimite" alignment="CENTER_RIGHT" styleClass="texto" textFill="#8eb83d" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                <Label text="Saldo a favor:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="7">

                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblSaldoFavor" alignment="CENTER_RIGHT" styleClass="texto" textFill="#8eb83d" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                <Label text="Adeudo:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="8">

                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

