                                <Button fx:id="btnEditar" disable="true" prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion" text="Editar" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="2" GridPane.rowSpan="2" />
                                <Button fx:id="btnImprimir" disable="true" prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion" text="Imprimir" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="4" GridPane.rowSpan="2" />
                                <Button fx:id="btnDarPlazo" disable="true" prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion" text="Dar plazo" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="6" GridPane.rowSpan="2" />
                                <Button fx:id="btnHistorial" disable="false" onAction="#historial" prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion" text="Historial" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="8" GridPane.rowSpan="2" />
                                <Button fx:id="btnEliminar" disable="true" prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion" text="Eliminar" textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="10" GridPane.rowSpan="2" />

                                <columnConstraints>
