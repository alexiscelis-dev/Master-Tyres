                                <Label text="Total:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="9">

                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <Label fx:id="lblTotal" alignment="CENTER_RIGHT" styleClass="texto" textFill="#8eb83d" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="9" />
