<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="ventanaNotas" prefHeight="600.0" prefWidth="1344.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/Nota.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.nota.NotaController">



    <AnchorPane layoutY="110.0" prefHeight="684.0" prefWidth="1244.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">

        <VBox>
            <BorderPane prefHeight="600" prefWidth="1186.0">

                <!-- Parte superior: buscador y botones -->
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <HBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
                            <TextField fx:id="txtBuscar" maxWidth="600.0" prefHeight="26.0" prefWidth="350.0" promptText="Buscar notas..." styleClass="buscador" HBox.hgrow="ALWAYS">
                        <font>
                           <Font name="System Bold" size="12.0" />
                        </font></TextField>

                            <DatePicker fx:id="dpBuscar" managed="false" prefHeight="26.0" prefWidth="150.0" promptText="Fecha..." visible="false" />

                            <CheckBox fx:id="chkRangoNota" managed="false" text="Rango" visible="false" />

                            <Label fx:id="lblHasta" managed="false" text="a" visible="false" />

                            <DatePicker fx:id="dpBuscarFin" managed="false" prefHeight="26.0" prefWidth="150.0" promptText="Fecha fin..." visible="false" />

                            <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#accionBuscar" prefHeight="26.0" prefWidth="40.0" styleClass="boton-accion">
                                <graphic>
                                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                        <image>
                                            <Image url="@/icons/lupa.png" />
                                        </image>
                                    </ImageView>
                                </graphic>
                                <tooltip>
                                    <Tooltip text="Buscar" />
                                </tooltip>
                            </Button>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="5.0">
                            <Label prefHeight="18.0" prefWidth="79.0" text="Buscar por:" textFill="WHITE">
                        <font>
                           <Font name="System Bold" size="12.0" />
                        </font></Label>
                            <ChoiceBox fx:id="atributoBusquedaNota" prefWidth="150.0" styleClass="choicebox-mini2">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Sin Filtro" />
                                        <String fx:value="Numero de nota" />
                                        <String fx:value="Numero de factura" />
                                        <String fx:value="Nombre del Cliente" />
                                        <String fx:value="Direccion" />
                                        <String fx:value="RFC" />
                                        <String fx:value="Vehiculo" />
                                        <String fx:value="Placas de vehiculo" />
                                        <String fx:value="Fecha de emicion" />
                                        <String fx:value="Fecha de vencimiento" />
                                        <String fx:value="Adeudo" />
                                        <String fx:value="Saldo a favor" />
                                        <String fx:value="Total" />
                                    </FXCollections>
                                </items>
                            </ChoiceBox>
                        </HBox>

                        <Button fx:id="btnRefrescar" mnemonicParsing="false" prefHeight="25.0" prefWidth="33.0" styleClass="boton-accion" text="">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                    <image>
                                        <Image url="@/icons/refresh.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <padding>
                            <Insets bottom="20.0" right="20.0" top="20.0" />
                        </padding>

