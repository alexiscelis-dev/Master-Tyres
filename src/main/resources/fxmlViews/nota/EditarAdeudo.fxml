<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="root" prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ActualizarAdeudo.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.fxControllers.EditarControllers.EditarAdeudoController">


    <VBox alignment="TOP_CENTER" layoutY="1.0" prefHeight="500.0" prefWidth="600.0">
        <Label styleClass="titulo" text="Actualizar adeudo ">
            <VBox.margin>
                <Insets bottom="60.0" top="20.0"/>
            </VBox.margin>

        </Label>


        <VBox alignment="TOP_CENTER" fillWidth="false" prefHeight="100" prefWidth="600.0">

            <VBox>
                <HBox fx:id="hbAdeudo" alignment="CENTER_LEFT" spacing="20" visible="true">
                    <TextField fx:id="txtAdeudo" prefHeight="26.0" prefWidth="250.0"
                               promptText="Ingrese el nuevo monto del adeudo" styleClass="buscador">

                    </TextField>


                    <DatePicker fx:id="dpFecha" editable="false" prefHeight="26.0" prefWidth="165.0"
                                promptText="Fecha de vencimiento" styleClass="date-picker">

                    </DatePicker>

                </HBox>
                <StackPane prefHeight="50" prefWidth="200" alignment="CENTER">
                    <CheckBox fx:id="cbLiquidar"  text="Liquidar adeudo"> </CheckBox>
                </StackPane>





            </VBox>


            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>

        </VBox>


        <HBox alignment="BOTTOM_CENTER" prefHeight="100" spacing="20">
            <Button onAction="#cancelar" fx:id="btnCancelar" styleClass="boton-accion" text="Cancelar"/>
            <Button disable="true" fx:id="btnActualizar" styleClass="boton-accion" text="Registrar"/>
        </HBox>

    </VBox>

</AnchorPane>
