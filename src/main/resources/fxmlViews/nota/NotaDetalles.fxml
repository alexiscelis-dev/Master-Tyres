<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;"
            stylesheets="/styles_css/Nota.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.nota.NotaDetallesController">

    <children>
        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20"/>
            </padding>

            <Label text="Informacion de la Nota" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="40.0"/>
                </font>
            </Label>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="LEFT" prefWidth="600.0"/>
                </columnConstraints>


                <Label fx:id="txtNumNota" text="Numero de nota:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtNumFactura" text="Numero de factura:" textFill="WHITE" GridPane.columnIndex="0"
                       GridPane.rowIndex="1">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtFechaVencimiento" text="Fecha de vencimiento:" textFill="WHITE" GridPane.columnIndex="0"
                       GridPane.rowIndex="2">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtAdeudo" text="Adeudo:" textFill="WHITE" GridPane.columnIndex="0"
                       GridPane.rowIndex="3">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtSaldo" text="Saldo:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtStatus" text="Estado:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="5">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtFechaCreacion" text="Fecha de creacion:" textFill="WHITE" GridPane.columnIndex="0"
                       GridPane.rowIndex="6">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>


                <Label fx:id="txtGenero" text="Género:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="9">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>

                <Label fx:id="txtTipoCliente" text="Tipo Cliente:" textFill="WHITE" GridPane.columnIndex="0"
                       GridPane.rowIndex="10">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>



                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0"/>
                </rowConstraints>
            </GridPane>

            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button styleClass="boton-accion" text="Cerrar"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
