<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #080808;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.Promociones.NuevaPromocionClienteController">

    <children>


        <VBox layoutX="100.0" layoutY="150.0" prefHeight="600.0" prefWidth="472.0" style="-fx-background-color: #1A1A1A;" styleClass="formulario" stylesheets="@../../styles_css/NuevaPromocion.css">

            <children>

                <HBox alignment="CENTER" prefHeight="33.0" prefWidth="460.0">

                    <children>

                        <Label alignment="TOP_CENTER" prefHeight="30.0" prefWidth="272.0" styleClass="seccion-titulo" text="Nueva Promocion" textFill="WHITE" />

                    </children>

                    <VBox.margin>

                        <Insets bottom="20.0" />

                    </VBox.margin>

                </HBox>

                <HBox prefHeight="28.0" prefWidth="333.0">

                    <children>

                        <Label text="Nombre de la promocion" textFill="WHITE">

                            <HBox.margin>

                                <Insets left="40.0" right="88.0" />

                            </HBox.margin>

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                        </Label>

                    </children>

                    <VBox.margin>

                        <Insets bottom="5.0" />

                    </VBox.margin>

                </HBox>

                <HBox prefHeight="34.0" prefWidth="376.0">

                    <children>

                        <TextField fx:id="nombrePromocion" prefHeight="26.0" prefWidth="348.0" styleClass="buscador">

                            <HBox.margin>

                                <Insets left="40.0" right="50.0" />

                            </HBox.margin>

                        </TextField>

                    </children>

                    <VBox.margin>

                        <Insets bottom="10.0" />

                    </VBox.margin>

                </HBox>

                <VBox prefHeight="115.0" prefWidth="432.0" spacing="6.0">

                    <children>

                        <Label text="Descripcion" textFill="WHITE">

                            <opaqueInsets>

                                <Insets />

                            </opaqueInsets>

                            <padding>

                                <Insets left="40.0" />

                            </padding>

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                        </Label>

                        <HBox alignment="CENTER" prefHeight="67.0" prefWidth="432.0">

                            <children>

                                <TextField fx:id="descripcion" prefHeight="45.0" prefWidth="348.0" styleClass="buscador" />

                            </children>

                        </HBox>

                    </children>

                    <padding>

                        <Insets top="5.0" />

                    </padding>

                </VBox>



                <HBox prefHeight="34.0" prefWidth="432.0">

                    <children>

                        <Label text="Tipo de descuento" textFill="WHITE">

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                            <padding>

                                <Insets bottom="5.0" />

                            </padding>

                            <HBox.margin>

                                <Insets left="40.0" right="56.0" />

                            </HBox.margin>

                        </Label>

                        <Label text="Precio sin descuento" textFill="WHITE">

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                            <HBox.margin>

                                <Insets left="40.0" />

                            </HBox.margin>

                        </Label>

                    </children>

                    <VBox.margin>

                        <Insets />

                    </VBox.margin>

                </HBox>

                <HBox prefHeight="40.0" prefWidth="432.0">

                    <children>

                        <ChoiceBox fx:id="tipoDescuento" prefWidth="150.0" styleClass="choicebox-mini2">

                            <HBox.margin>

                                <Insets left="40.0" right="38.0" />

                            </HBox.margin>

                            <items>



                            </items>





                        </ChoiceBox>

                        <TextField fx:id="precioSinDescuento" disable="true" prefHeight="26.0" prefWidth="156.0" styleClass="buscador">

                            <opaqueInsets>

                                <Insets />

                            </opaqueInsets>

                            <HBox.margin>

                                <Insets />

                            </HBox.margin>

                        </TextField>

                    </children>

                    <VBox.margin>

                        <Insets bottom="15.0" />

                    </VBox.margin>

                </HBox>

                <HBox prefHeight="44.0" prefWidth="393.0">

                    <children>

                        <VBox alignment="CENTER" prefHeight="44.0" prefWidth="392.0">

                            <children>

                                <Slider fx:id="porcentajeDescuento" disable="true" prefHeight="14.0" prefWidth="340.0">

                                    <VBox.margin>

                                        <Insets bottom="5.0" />

                                    </VBox.margin>

                                    <padding>

                                        <Insets left="40.0" />

                                    </padding>

                                </Slider>

                                <Label fx:id="descuentoLabel" text="Descuento 0% " textFill="WHITE">

                                    <font>

                                        <Font name="System Bold" size="12.0" />

                                    </font>

                                    <VBox.margin>

                                        <Insets left="30.0" />

                                    </VBox.margin>

                                </Label>

                            </children>

                        </VBox>

                    </children>

                    <VBox.margin>

                        <Insets bottom="20.0" />

                    </VBox.margin>

                </HBox>





                <HBox prefHeight="26.0" prefWidth="432.0">

                    <children>

                        <Label prefHeight="18.0" prefWidth="212.0" text="Fecha de inicio" textFill="WHITE">

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                            <padding>

                                <Insets left="40.0" />

                            </padding>

                            <HBox.margin>

                                <Insets right="25.0" />

                            </HBox.margin>

                        </Label>



                        <Label prefHeight="18.0" prefWidth="120.0" text="Fecha de fin" textFill="WHITE">

                            <font>

                                <Font name="System Bold" size="12.0" />

                            </font>

                        </Label>





                    </children>

                    <VBox.margin>

                        <Insets bottom="5.0" />





                    </VBox.margin>

                </HBox>





                <HBox prefHeight="49.0" prefWidth="432.0" stylesheets="@../../styles_css/ClientesStyles.css">

                    <children>

                        <DatePicker fx:id="fechaInicio" disable="true" editable="false" prefHeight="26.0" prefWidth="159.0" styleClass="date-picker">

                            <HBox.margin>

                                <Insets right="35.0" />

                            </HBox.margin>

                        </DatePicker>

                        <DatePicker fx:id="fechaFin" disable="true" editable="false" prefHeight="26.0" prefWidth="158.0" styleClass="date-picker" />

                    </children>

                    <VBox.margin>

                        <Insets left="40.0" />

                    </VBox.margin>

                </HBox>

                <HBox alignment="CENTER" prefHeight="98.0" prefWidth="432.0">

                    <children>

                        <TextField fx:id="textFieldImg" editable="false" prefHeight="26.0" prefWidth="204.0" promptText="Seleccionar imagen (Opcional)" styleClass="buscador-img" />



                        <Button fx:id="btnImagen" disable="true" mnemonicParsing="false" prefHeight="17.0" prefWidth="28.0" styleClass="boton-img" text="..." />

                    </children>

                </HBox>



            </children>

        </VBox>

        <VBox layoutX="600.0" layoutY="150.0" prefHeight="600.0" prefWidth="540.0" style="-fx-background-color: #1A1A1A;" styleClass="formulario" stylesheets="@../../styles_css/NuevaPromocion.css">

            <padding>
                <Insets bottom="15" left="20" right="20" top="20" />
            </padding>

            <children>

                <!-- TÍTULO -->
                <Label maxWidth="Infinity" styleClass="seccion-titulo" text="Clientes Participantes">
                    <VBox.margin>
                        <Insets bottom="15" />
                    </VBox.margin>
                </Label>

                <!-- BUSCADOR -->
                <HBox spacing="10">
                    <TextField fx:id="txtBuscador" promptText="Buscar cliente..." styleClass="buscador" HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnBuscar" styleClass="boton-accion">
                        <graphic>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <image>
                                    <Image url="@/icons/lupa.png" />
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                </HBox>

                <!-- TABLA -->
                <TableView fx:id="tablaClientes" prefHeight="300" styleClass="tabla-promocion" VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colSeleccionCliente" prefWidth="25" />
                        <TableColumn fx:id="colNombre" prefWidth="160" text="Nombre" />
                        <TableColumn fx:id="colNombreEmpresa" prefWidth="80" text="Empresa" />
                        <TableColumn fx:id="colTipoCliente" prefWidth="80" text="Tipo" />
                        <TableColumn fx:id="colRFC" prefWidth="110" text="RFC" />
                        <TableColumn fx:id="colCumpleanos" prefWidth="75" text="Cumpleaños" />
                        <TableColumn fx:id="colFechaRegistro" prefWidth="75" text="Registro" />
                        <TableColumn fx:id="colHobbie" prefWidth="80" text="Hobbie" />
                    </columns>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>


                </TableView>

                <!-- PAGINADOR -->
                <Pagination fx:id="PaginadorClientes" maxPageIndicatorCount="5" prefHeight="50" />

               <HBox spacing="5">
                   <!-- CLIENTES AGREGADOS -->
                   <Label style="-fx-font-weight: bold;" text="Clientes Agregados:" textFill="WHITE">
                       <VBox.margin>
                           <Insets top="5" />
                       </VBox.margin>
                   </Label>

                   <Label fx:id="statusLabel" textAlignment="LEFT" alignment="CENTER_LEFT" maxWidth="Infinity"  prefHeight="15.0" prefWidth="300.0" text="" textFill="WHITE" visible="true">
                       <VBox.margin>
                           <Insets top="15.0" />
                       </VBox.margin>
                       <font>
                           <Font name="Roboto Bold" size="12.0" />
                       </font>
                   </Label>

               </HBox>

                <ListView fx:id="clientesAgregados" prefHeight="120" styleClass="ListaClientes" />

                <!-- BOTONES -->
                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnRegistrar" prefWidth="120" styleClass="boton-accion" text="Agregar" />
                    <Button fx:id="btnLimpiar" prefWidth="120" styleClass="boton-accion" text="Limpiar" />
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
                </HBox>


            </children>

        </VBox>





    </children>
</AnchorPane>
