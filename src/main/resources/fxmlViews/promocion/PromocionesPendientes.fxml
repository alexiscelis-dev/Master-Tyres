<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles-css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.controllers.fxControllers.Promociones.PromocionesPendientes">

    <children>
        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="60">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <VBox alignment="TOP_CENTER">

                <Label text="Promociones Pendientes" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>


            </VBox>

            <VBox>
                <HBox alignment="CENTER" spacing="20">

                    <Button onAction="#SeleccionarTodos" prefWidth="200.0" styleClass="boton-accion" text="Seleccionar todos" />
                    <Button onAction="#DeseleccionarTodos" prefWidth="200.0" styleClass="boton-accion" text="Deseleccionar todos" />

                </HBox>

            </VBox>


            <TableView fx:id="tablaPromociones">
                <columns>
                    <TableColumn fx:id="colCheckBox" prefWidth="35.0" style="-fx-alignment:CENTER;" text="" />
                    <TableColumn fx:id="colNombre" prefWidth="130.0" text="Nombre" />
                    <TableColumn fx:id="colFechaInicio" prefWidth="100.0" text="Activacion:" />
                    <TableColumn fx:id="colFechaFin" prefWidth="100.0" text="Finalizacion:" />
                    <TableColumn fx:id="colDescripcion" prefWidth="220.0" text="Descripcion" />
                </columns>
            </TableView>


            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#Eliminar" prefWidth="200.0" styleClass="boton-accion" text="Eliminar Seleccionados" />
                <Button onAction="#cerrarVentana" prefWidth="200.0" styleClass="boton-accion" text="Cerrar" />
            </HBox>
        </VBox>

        <fx:include source="/fxmlComponentes/Components/TitleBar/modalTittleBar/TittleBarModalComponent.fxml" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
    </children>
</AnchorPane>
