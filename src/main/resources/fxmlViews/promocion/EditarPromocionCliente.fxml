<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="572.0" prefWidth="1220.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.Promociones.EditarPromocionControllerCliente">

    <children>
        <HBox alignment="TOP_CENTER" prefHeight="572.0" prefWidth="1220.0" spacing="20">

            <!-- FORMULARIO PROMOCION -->
            <VBox alignment="CENTER" prefHeight="500" prefWidth="600" spacing="10" styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label styleClass="seccion-titulo" text="Editar Promocion" />

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="150" />
                        <ColumnConstraints prefWidth="350.0" />
                    </columnConstraints>

                    <!-- Nombre -->
                    <Label text="Nombre de la promocion:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtNombre" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- Descripcion -->
                    <Label text="Descripcion:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextArea fx:id="txtDescripcion" prefHeight="45.0" prefWidth="348.0" styleClass="TextAreaDescripcion" GridPane.columnIndex="1" GridPane.rowIndex="1" >
                        <font>
                            <Font name="System Bold" size="12.0" />
                        </font></TextArea>

                    <!-- Precio sin descuento -->
                    <Label text="Precio sin descuento:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtPrecio" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Tipo Descuento -->
                    <Label text="Precio con descuento:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <TextField fx:id="precioConDescuento" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="buscador" />
<!--                    <ChoiceBox fx:id="txtTipoDescuento" styleClass="choicebox-mini" GridPane.columnIndex="1" GridPane.rowIndex="3" />-->

                    <!-- Porcentaje -->
                    <Label text="Porcentaje:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <Slider fx:id="porcentajeDescuento" prefHeight="14.0" prefWidth="340.0" />
                        <Label fx:id="porcentaje" minWidth="40.0" />
                    </HBox>

                    <!-- Fecha Inicio -->
                    <Label text="Fecha de inicio:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <DatePicker fx:id="dateInicio" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <!-- Fecha Fin -->
                    <Label text="Fecha del fin:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <DatePicker fx:id="dateFin" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                    <!-- Imagen -->
                    <Label text="Imagen:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="7">
                        <TextField fx:id="txtRutaImagen" editable="false" prefHeight="26.0" prefWidth="253.0" promptText="Seleccionar imagen (Opcional)" styleClass="buscador-img" />
                        <Button fx:id="btnSeleccionarImagen" onAction="#seleccionarImagen" prefHeight="26.0" prefWidth="111.0" styleClass="boton-img" text="..." />
                    </HBox>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>


                </GridPane>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnCambiar" styleClass="boton-accion" text="Cambiar" />
                    <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cancelar" />
                </HBox>
            </VBox>

            <!-- VEHÍCULOS PARTICIPANTES -->
            <VBox alignment="CENTER" minWidth="400.0" prefHeight="500.0" prefWidth="600.0" spacing="15.0" styleClass="secciones">
                <padding>
                    <Insets bottom="15" left="20" right="20" top="20" />
                </padding>

                    <!-- TÍTULO -->
                    <Label alignment="CENTER" maxWidth="Infinity" styleClass="seccion-titulo" text="Clientes Participantes">
                        <VBox.margin>
                            <Insets bottom="15" />
                        </VBox.margin>
                    </Label>

                    <!-- BUSCADOR -->
                    <HBox spacing="10">
                        <TextField fx:id="txtBuscador" promptText="Buscar cliente..." styleClass="buscador" HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnBuscar" styleClass="boton-accion">
                            <graphic>
                                <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                    <image>
                                        <Image url="@/icons/lupa.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>

                    <!-- TABLA -->
                    <TableView fx:id="Tabla_Clientes" prefHeight="200.0" styleClass="tabla-promocion" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSeleccionCliente" prefWidth="25" />
                            <TableColumn fx:id="colNombre" prefWidth="160" text="Nombre" />
                            <TableColumn fx:id="colNombreEmpresa" prefWidth="80" text="Empresa" />
                            <TableColumn fx:id="colTipoCliente" prefWidth="80" text="Tipo" />
                            <TableColumn fx:id="colRFC" prefWidth="110" text="RFC" />
                            <TableColumn fx:id="colCumpleanos" prefWidth="75" text="Cumpleaños" />
                            <TableColumn fx:id="colFechaRegistro" prefWidth="75" text="Registro" />
                            <TableColumn fx:id="colHobbie" prefWidth="80" text="Hobbie" />
                        </columns>
                        <VBox.margin>
                            <Insets top="10.0" />
                        </VBox.margin>
                    </TableView>

                    <!-- PAGINADOR -->
                    <Pagination fx:id="PaginadorClientes" maxPageIndicatorCount="5" prefHeight="50" />

                    <!-- CLIENTES AGREGADOS -->
                    <Label style="-fx-font-weight: bold;" text="Clientes Agregados:" textFill="WHITE">
                        <VBox.margin>
                            <Insets top="5" />
                        </VBox.margin>
                    </Label>

                    <ListView fx:id="ClientesAgregados" prefHeight="120" styleClass="ListaClientes" />
            </VBox>
        </HBox>
    </children>
</AnchorPane>
