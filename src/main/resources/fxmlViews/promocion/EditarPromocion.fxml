<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.Promociones.EditarPromocionController">

    <children>
        <HBox alignment="TOP_CENTER" spacing="20">

            <!-- FORMULARIO PROMOCION -->
            <VBox alignment="CENTER" prefHeight="500" prefWidth="600" spacing="10" styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label styleClass="seccion-titulo" text="Editar Promocion" />

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="150" />
                        <ColumnConstraints prefWidth="350.0" />
                    </columnConstraints>

                    <!-- Nombre -->
                    <Label text="Nombre de la promocion:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <TextField fx:id="txtNombre" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- Descripcion -->
                    <Label text="Descripcion:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <TextField fx:id="txtDescripcion" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- Precio sin descuento -->
                    <Label text="Precio sin descuento:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <TextField fx:id="txtPrecio" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Tipo Descuento -->
                    <Label text="Tipo Descuento:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <ChoiceBox fx:id="txtTipoDescuento" styleClass="choicebox-mini" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <!-- Porcentaje -->
                    <Label text="Porcentaje:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <Slider fx:id="porcentajeDescuento" prefHeight="14.0" prefWidth="340.0" />
                        <Label fx:id="porcentaje" minWidth="40.0" />
                    </HBox>

                    <!-- Fecha Inicio -->
                    <Label text="Fecha de inicio:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                    <DatePicker fx:id="dateInicio" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                    <!-- Fecha Fin -->
                    <Label text="Fecha del fin:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                    <DatePicker fx:id="dateFin" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                    <!-- Imagen -->
                    <Label text="Imagen:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                    <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="7">
                        <TextField fx:id="txtRutaImagen" editable="false" prefHeight="26.0" prefWidth="253.0" promptText="Seleccionar imagen (Opcional)" styleClass="buscador-img" />
                        <Button fx:id="btnSeleccionarImagen" onAction="#seleccionarImagen" prefHeight="26.0" prefWidth="111.0" styleClass="boton-img" text="..." />
                    </HBox>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>


                </GridPane>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnCambiar" styleClass="boton-accion" text="Cambiar" />
                    <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cancelar" />
                </HBox>
            </VBox>

            <!-- VEHÍCULOS PARTICIPANTES -->
            <VBox alignment="CENTER" minWidth="400.0" prefHeight="500.0" prefWidth="600.0" spacing="15.0" styleClass="secciones">
                <padding>
                    <Insets bottom="20" left="20" right="20" top="20" />
                </padding>

                <Label styleClass="seccion-titulo" text="Vehículos participantes" />

                <!-- ChoiceBoxes -->
                <HBox alignment="TOP_CENTER" spacing="5">
                    <ChoiceBox fx:id="choiceMarca" prefWidth="160.0" styleClass="choicebox-mini2" />
                    <ChoiceBox fx:id="choiceModelo" prefWidth="160.0" styleClass="choicebox-mini2" />
                    <ChoiceBox fx:id="choiceAnio" prefHeight="26.0" prefWidth="160.0" styleClass="choicebox-mini2" />
                </HBox>

                <!-- Botón Agregar -->
                <Button fx:id="btnAgregarVehiculo" styleClass="boton-accion" text="Agregar Vehículo" />

                <!-- Tabla -->
                <TableView fx:id="tableVehiculosParticipantes" maxWidth="385.0" prefHeight="222.0" prefWidth="385.0">
                    <columns>
                        <TableColumn fx:id="colMarca" prefWidth="120.0" text="Marca" />
                        <TableColumn fx:id="colModelo" prefWidth="120.0" text="Modelo" />
                        <TableColumn fx:id="colAnio" prefWidth="88.99998474121094" text="Año" />
                        <TableColumn fx:id="colEliminar" prefWidth="51.0" style="-fx-alignment:CENTER;" text="Acción" />
                    </columns>
                </TableView>
            </VBox>

        </HBox>

    </children>
</AnchorPane>
