<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.vehiculo.detalleVehiculo">

    <children>
        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label text="Informacion del cliente" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="40.0" />
                </font></Label>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="LEFT" prefWidth="600.0" />
                </columnConstraints>

                <!-- Nombre -->
                <Label fx:id="txtMarca" prefWidth="550.0" text="Marca:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Primer Apellido -->
                <Label fx:id="txtModelo" prefWidth="550.0" text="Modelo:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Segundo Apellido -->
                <Label fx:id="txtannio" prefWidth="550.0" text="Año:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Teléfono -->
                <Label fx:id="txtCategoria" prefWidth="550.0" text="categoria:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Hobbie -->
                <Label fx:id="txtKilometros" prefWidth="550.0" text="Kilometros:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="4">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- RFC -->
                <Label fx:id="txtColor" prefWidth="550.0" text="Color:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="5">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Domicilio -->
                <Label fx:id="txtPlacas" prefWidth="550.0" text="Placas:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="6">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Estado -->
                <Label fx:id="txtNumeroSerie" prefWidth="550.0" text="Numero de serie:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="7">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Ciudad -->
                <Label fx:id="txtObservaciones" prefWidth="550.0" text="Observaciones:" textFill="WHITE" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="8">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font></Label>

                <!-- Género -->
                <Label fx:id="txtUltimoServicio" prefWidth="550.0" text="Ultimo Servicio:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="9">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Label fx:id="txtFechaRegistro" prefWidth="550.0" text="Fecha de registro:" textFill="WHITE" GridPane.rowIndex="10">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Label fx:id="txtFechaActualizacion" prefWidth="550.0" text="Fecha de la ultima actualizacion: " textFill="WHITE" GridPane.rowIndex="11">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>

            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cerrar" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
