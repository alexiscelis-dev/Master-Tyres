<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="300" prefWidth="450" style="-fx-background-color: #0A0A0A;"
            stylesheets="/styles_css/stylesLogin.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.login.recuperarPassword.RecuperarPasswordController">

    <children>

        <!-- Contenedor centralizado -->
        <VBox alignment="CENTER" spacing="20" prefWidth="400" layoutX="25" layoutY="50">

            <!-- Título principal -->
            <Label text="Recuperar contraseña" styleClass="title" textAlignment="CENTER" wrapText="true"/>

            <!-- Subtítulo / instrucciones -->
            <Label text="Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña."
                   style="-fx-text-fill:white; -fx-font-size: 12px;" wrapText="true" textAlignment="CENTER" maxWidth="400"/>

            <!-- Campo de correo -->
            <TextField fx:id="txtCorreoRecuperacion" promptText="Correo electrónico"
                       styleClass="input-field" prefWidth="350" maxWidth="350"/>

            <!-- Botón enviar -->
            <Button fx:id="btnEnviar" text="Enviar enlace de recuperación"
                    styleClass="login-button" prefWidth="350" prefHeight="40" onAction="#close"/>

            <!-- Mensaje de feedback dinámico -->
            <Label fx:id="lblMensaje" text="" styleClass="feedback-label" wrapText="true" textAlignment="CENTER" maxWidth="350"/>

        </VBox>

    </children>
</AnchorPane>