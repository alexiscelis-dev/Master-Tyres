<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="rootPane" prefHeight="383.0" prefWidth="835.0" styleClass="root"
            stylesheets="/styles_css/stylesLogin.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.controllers.fxControllers.login.LoginController">

    <children>


        <StackPane fx:id="Panel" layoutX="49.0" prefHeight="383.0" prefWidth="926.0" AnchorPane.bottomAnchor="0"
                   AnchorPane.leftAnchor="49.0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">



            <HBox alignment="CENTER" spacing="0">

                <!-- Login Form -->
                <VBox alignment="CENTER" maxHeight="500" maxWidth="451.0" prefHeight="383.0" prefWidth="451.0" spacing="20"
                      styleClass="login-container">
                    <Label styleClass="title" text="Login"/>
                    <TextField fx:id="txtCorreo" promptText="Correo electrónico" styleClass="input-field"/>



                        <GridPane  AnchorPane.topAnchor="0">
                            <columnConstraints>
                                <ColumnConstraints />
                                <ColumnConstraints />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints/>
                            </rowConstraints>

                            <children>

                                <PasswordField prefWidth="350" visible="true" GridPane.columnIndex="0" GridPane.rowIndex="0" fx:id="pfPassword" promptText="Contraseña" styleClass="input-field">

                                </PasswordField>

                                <TextField prefWidth="350" visible="false" GridPane.columnIndex="0" GridPane.rowIndex="0" fx:id="txtPasswordVisible" promptText="Contraseña" styleClass="input-field">

                                </TextField>

                                <Button onAction="#togglePassword" fx:id="btnTogglePassword" styleClass="password-button" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <graphic>
                                        <ImageView fx:id="imageEye" fitHeight="20" fitWidth="20">
                                            <image >
                                                <Image url="@../../icons/visibility.png"/>
                                            </image>
                                        </ImageView>
                                    </graphic>

                                </Button>




                            </children>

                        </GridPane>




                    <Button fx:id="loginButton" prefHeight="26.0" prefWidth="451.0" styleClass="login-button"
                            text="Iniciar sesión." onAction="#logIn"/>


                    <Hyperlink fx:id="forgotPassword" styleClass="forgot-link" text="¿Has olvidado tu contraseña?"/>
                    <Label fx:id="errorLabel" styleClass="error-label" text="" visible="false"/>
                </VBox>

                <!-- Contenedor del logo con fondo -->
                <StackPane maxHeight="500" maxWidth="451.0" prefHeight="383.0" prefWidth="451.0"
                           style="-fx-background-color: #FFFFFF;  -fx-padding: 20; -fx-background-radius: 10;">
                    <ImageView fx:id="logoImage" fitHeight="200" preserveRatio="true">
                        <image>
                            <Image url="@../../icons/Master Tyres Logo.png"/>
                        </image>
                    </ImageView>
                </StackPane>

            </HBox>
        </StackPane>

        <HBox AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0"
              style="-fx-background-color: #8EB83D;" alignment="CENTER">
            <Label fx:id="footerLabel" text="© 2025 Master Tyres. Todos los derechos reservados."
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 12px; "
                   AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                   alignment="CENTER"/>
        </HBox>

        <fx:include fx:id="loadingOverlay"
                    source="/fxmlComponentes/Components/Loader/LoadingComponent.fxml"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0"/>

        <fx:include
                source="/fxmlComponentes/Components/TitleBar/TitleBarComponent.fxml"
                AnchorPane.topAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0"/>

    </children>
</AnchorPane>
