<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1344.0"
            style="-fx-background-color: #080808;" stylesheets="/styles_css/PaginaPrincipal.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.configuracion.ConfiguracionController">

    <children>

        <AnchorPane layoutX="14.0" layoutY="121.0" prefHeight="479.0" prefWidth="1152.0"
                    style="-fx-background-color: #080808;" styleClass="clientes-panel"
                    stylesheets="/styles_css/ConfiguracionStyle.css" AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="178.0" AnchorPane.topAnchor="121.0"
                    xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

            <BorderPane prefHeight="479.0" prefWidth="1152.0"
                        styleClass="root-pane">


                <!-- ── TÍTULO ── -->
                <top>
                    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="12">
                        <Label text="⚙" styleClass="header-icon"/>
                        <Label text="Configuración" styleClass="header-title"/>
                    </HBox>
                </top>

                <!-- ── CONTENIDO PRINCIPAL ── -->
                <center>
                    <HBox>

                        <!-- IZQUIERDA: Panel de detalles-->
                        <StackPane fx:id="detailContainer" HBox.hgrow="ALWAYS"
                                   styleClass="detail-container">

                            <!-- ── PANEL VACÍO / BIENVENIDA ── -->
                            <VBox fx:id="panelBienvenida" styleClass="detail-panel" visible="true"
                                  alignment="CENTER" spacing="16">
                                <Label text="👋" styleClass="welcome-icon"/>
                                <Label text="Selecciona una opción" styleClass="welcome-text"/>
                                <Label text="Elige una sección del menú de la derecha para comenzar."
                                       styleClass="welcome-sub" wrapText="true" textAlignment="CENTER"/>
                            </VBox>

                            <!-- PERFIL-->

                            <!-- Ver perfil -->
                            <VBox fx:id="panelVerPerfil" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Ver Perfil" styleClass="panel-title"/>
                                <Separator/>
                                <HBox spacing="24" alignment="CENTER_LEFT">
                                    <VBox alignment="CENTER" spacing="8">
                                        <ImageView fx:id="avatarImageView" fitWidth="90" fitHeight="90"
                                                   styleClass="avatar-view" preserveRatio="true">
                                            <image><Image url="/icons/user.png" /></image>
                                        </ImageView>
                                    </VBox>
                                    <VBox spacing="6">
                                        <Label fx:id="lblNombreCompleto" text="Nombre de usuario"
                                               styleClass="profile-name"/>
                                        <Label fx:id="lblCorreo" text="correo@ejemplo.com"
                                               styleClass="profile-email"/>
                                        <Label fx:id="lblRol" text="Rol: Administrador"
                                               styleClass="profile-role"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <GridPane hgap="16" vgap="10" styleClass="info-grid">
                                    <Label text="Usuario:" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Label fx:id="lblUsernameInfo" text="—" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                    <Label text="Correo:" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Label fx:id="lblCorreoInfo" text="—" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                    <Label text="Miembro desde:" styleClass="info-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <Label fx:id="lblFechaRegistro" text="—" styleClass="info-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                </GridPane>
                            </VBox>

                            <!-- Cambiar Contraseña -->
                            <VBox fx:id="panelCambiarContrasena" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Cambiar Contraseña" styleClass="panel-title"/>
                                <Separator/>
                                <VBox spacing="14" maxWidth="400">
                                    <VBox spacing="4">
                                        <Label prefWidth="400" text="Contraseña actual" styleClass="field-label"/>

                                        <GridPane>
                                            <columnConstraints>
                                                <ColumnConstraints/>
                                                <ColumnConstraints/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                    <RowConstraints/>
                                            </rowConstraints>

                                            <children>
                                                <PasswordField prefWidth="400" visible="true" GridPane.columnIndex="0" GridPane.rowIndex="0" fx:id="pfContrasenaActual" promptText="••••••••" styleClass="field-input"/>

                                                <TextField fx:id="txtContrasenaActualVisible" visible="false" prefWidth="400" GridPane.columnIndex="0" GridPane.rowIndex="0"  promptText="••••••••" styleClass="field-input"></TextField>



                                                <Button fx:id="btnTogglePassword" styleClass="show-eye" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <graphic>
                                                        <ImageView fx:id="imageEye" fitHeight="20" fitWidth="20">
                                                            <image >
                                                                <Image url="@../../icons/visibility.png"/>
                                                            </image>
                                                        </ImageView>
                                                    </graphic>

                                                </Button>

                                            </children>

                                        </GridPane>


                                        <Label visible="false" fx:id="lblContrasenaError" text="Contraseña incorrecta" style="-fx-text-fill: red;-fx-font-size:8px;"></Label>
                                    </VBox>
                                    <VBox spacing="4">
                                        <Label text="Nueva contraseña" styleClass="field-label"/>
                                    </VBox>
                                    <VBox spacing="4">

                                        <GridPane  AnchorPane.topAnchor="0">
                                            <columnConstraints>
                                                <ColumnConstraints/>
                                                <ColumnConstraints/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints/>

                                            </rowConstraints>

                                            <children>

                                                <PasswordField visible="true" prefWidth="400" GridPane.columnIndex="0" GridPane.rowIndex="0" fx:id="pfNuevaContrasena" promptText="••••••••" styleClass="field-input"/>
                                                <TextField fx:id="txtNuevaContrasenaVisible" visible="false" prefWidth="400" GridPane.columnIndex="0" GridPane.rowIndex="0"  styleClass="field-input">

                                                </TextField>

                                                <Button fx:id="btnTogglePassword2" styleClass="show-eye" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <graphic>
                                                        <ImageView fx:id="imageEye2" fitHeight="20" fitWidth="20">
                                                            <image >
                                                                <Image url="@../../icons/visibility.png"/>
                                                            </image>
                                                        </ImageView>
                                                    </graphic>

                                                </Button>

                                            </children>
                                        </GridPane>



                                        <Label  text="Confirmar nueva contraseña" styleClass="field-label"/>

                                        <GridPane AnchorPane.topAnchor="0">
                                            <columnConstraints>
                                                <ColumnConstraints/>
                                                <ColumnConstraints/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints/>
                                            </rowConstraints>

                                            <children>

                                                <PasswordField visible="true" prefWidth="400" GridPane.columnIndex="0" GridPane.rowIndex="0"  fx:id="pfConfirmarContrasena" promptText="••••••••" styleClass="field-input"/>
                                                <TextField fx:id="txtConfirmarContrasenaVisible" visible="false" prefWidth="400" GridPane.columnIndex="0" GridPane.rowIndex="0"  promptText="••••••••" styleClass="field-input"></TextField>

                                                <Button   fx:id="btnTogglePassword3" styleClass="show-eye" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <graphic>
                                                        <ImageView fx:id="imageEye3" fitHeight="20" fitWidth="20">
                                                            <image >
                                                                <Image url="@../../icons/visibility.png"/>
                                                            </image>
                                                        </ImageView>
                                                    </graphic>

                                                </Button>

                                            </children>

                                        </GridPane>


                                        <Label  visible="false" fx:id="lblContrasenaError2" text="" style="-fx-text-fill: red;-fx-font-size:8px;"></Label>


                                    </VBox>
                                    <ProgressBar fx:id="passwordStrengthBar" progress="0" maxWidth="Infinity"
                                                 styleClass="strength-bar"/>
                                    <Label fx:id="lblPasswordStrength" text="" styleClass="strength-label"/>
                                    <Button fx:id="btnCambiarContrasena" text="Guardar contraseña"
                                            styleClass="boton-accion"
                                            onAction="#onCambiarContrasena"/>
                                </VBox>
                            </VBox>



                            <!-- Cambiar Nombre de Usuario -->
                            <VBox fx:id="panelCambiarNombreUsuario" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Cambiar Nombre de Usuario" styleClass="panel-title"/>
                                <Separator/>
                                <VBox spacing="14" maxWidth="400">
                                    <VBox spacing="4">
                                        <Label text="Nombre de usuario actual" styleClass="field-label"/>
                                        <Label fx:id="lblNombreUsuarioActual" text="usuario123" styleClass="info-value"/>
                                    </VBox>
                                    <VBox spacing="4">
                                        <Label text="Nuevo nombre de usuario" styleClass="field-label"/>
                                        <TextField fx:id="txtNuevoNombreUsuario" promptText="Nuevo usuario" styleClass="buscador"/>
                                    </VBox>
                                    <Button fx:id="btnCambiarNombreUsuario" text="Guardar"
                                            styleClass="boton-accion"
                                            onAction="#onCambiarNombreUsuario"/>
                                </VBox>
                            </VBox>

                            <!-- Cambiar Foto de Perfil -->
                            <VBox fx:id="panelCambiarFoto" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Cambiar Foto de Perfil" styleClass="panel-title"/>
                                <Separator/>
                                <HBox spacing="24" alignment="CENTER_LEFT">
                                    <VBox alignment="CENTER" spacing="10">
                                        <ImageView  fx:id="avatarPreview" fitWidth="110" fitHeight="110"
                                                   styleClass="avatar-view" preserveRatio="true">
                                            <image><Image url="/icons/user.png"/></image>
                                        </ImageView>
                                        <HBox>
                                            <TextField editable="false"  fx:id="txtRutaImg" styleClass="buscador-img" promptText="Selecione una imagen" />
                                            <Button fx:id="btnSeleccionarFoto" text="..."
                                                    styleClass="boton-img"
                                                    onAction="#onSeleccionarFoto"/>
                                        </HBox>

                                    </VBox>
                                    <VBox spacing="8">
                                        <Label text="Requisitos:" styleClass="field-label"/>
                                        <Label text="• Formato: JPG, JPEG, PNG " styleClass="hint-label"/>
                                    </VBox>
                                </HBox>
                                <HBox spacing="5">
                                    <Button fx:id="btnGuardarFoto" text="Guardar foto"
                                            styleClass="boton-accion"
                                            onAction="#onGuardarFoto"/>
                                    <Button fx:id="btnEliminarFoto" text="Eliminar Foto"
                                    styleClass="boton-accion"
                                    onAction="#onEliminarFoto" ></Button>

                                </HBox>

                            </VBox>

                            <!-- ALMACENAMIENTO   -->

                            <!-- Crear Respaldo -->
                            <VBox fx:id="panelCrearRespaldo" styleClass="detail-panel" visible="false" spacing="20">

                                <Label text="Crear Respaldo en la Nube" styleClass="panel-title"/>
                                <Separator/>
                                <VBox spacing="12" maxWidth="440">
                                    <Label text="Genera una copia de seguridad de todos tus datos en la Nube."
                                           styleClass="hint-label" wrapText="true"/>

                                    <Button fx:id="btnRespaldo" onAction="#crearRespaldo" styleClass="boton-accion" text="Hacer Respaldo"/>

                                    <ProgressBar fx:id="respaldoProgress" progress="0" maxWidth="Infinity"
                                                 visible="false" styleClass="strength-bar"/>
                                    <Label fx:id="lblRespaldoEstado" text="" styleClass="hint-label"/>
                                </VBox>
                            </VBox>

                            
                            <!-- Fecha Último Respaldo -->
                            <VBox fx:id="panelFechaRespaldo" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Fecha de Último Respaldo" styleClass="panel-title"/>
                                <Separator/>
                                <VBox spacing="14">
                                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="info-card">
                                        <Label text="📅" styleClass="info-card-icon"/>
                                        <VBox spacing="4">
                                            <Label text="Último respaldo realizado:" styleClass="field-label"/>
                                            <Label fx:id="lblFechaUltimoRespaldo" text="—" styleClass="profile-name"/>
                                        </VBox>
                                    </HBox>
                                    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="info-card">
                                        <Label text="💿" styleClass="info-card-icon"/>
                                        <VBox spacing="4">
                                            <Label text="Tamaño del último respaldo:" styleClass="field-label"/>
                                            <Label fx:id="lblTamanoRespaldo" text="—" styleClass="info-value"/>
                                        </VBox>
                                    </HBox>

                                </VBox>
                            </VBox>

                            <!-- AYUDA -->


                            <!-- Contacto -->
                            <VBox fx:id="panelContacto" styleClass="detail-panel" visible="false" spacing="20">
                                <Label text="Informacion" styleClass="panel-title"/>
                                <Separator/>
                                <VBox spacing="16" maxWidth="440">
                                    <HBox spacing="30">
                                        <VBox spacing="4">
                                            <Label text="Correo:" styleClass="field-label"/>
                                            <Label text="soporte@tuapp.com" styleClass="info-value"/>
                                        </VBox>
                                        <VBox spacing="4">
                                            <Label text="Versión de la app:" styleClass="field-label"/>
                                            <Label fx:id="lblVersion" text="v1.0.0" styleClass="info-value"/>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>

                        </StackPane>
                        <!-- FIN PANEL IZQUIERDO -->


                        <!-- DERECHA: Árbol de secciones-->
                        <VBox styleClass="sidebar" minWidth="220" maxWidth="260">
                            <TreeView fx:id="menuTree" VBox.vgrow="ALWAYS" styleClass="nav-tree"
                                      showRoot="false">
                                <!-- El controlador construye el árbol programáticamente
                                     para asociar cada TreeItem con su fx:id de panel.
                                     Ejemplo de estructura en el controlador:-->
                            </TreeView>
                        </VBox>
                        <!-- FIN SIDEBAR DERECHA -->

                    </HBox>
                </center>


            </BorderPane>





        </AnchorPane>
    </children>
</AnchorPane>
