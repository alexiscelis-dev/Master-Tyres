<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles-css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.controllers.fxControllers.Promociones.ClientesAplicablesController">

    <children>


        <VBox alignment="CENTER" prefHeight="600.0" prefWidth="600" spacing="10" styleClass="secciones"

              AnchorPane.topAnchor="20.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
        >

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <VBox>

                <Label text="Clientes aplicables a la promocion" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>


            </VBox>

            <VBox>
                <HBox alignment="CENTER" spacing="20">

                    <Button onAction="#SeleccionarTodos" prefWidth="200.0" styleClass="boton-accion" text="Seleccionar todos" />
                    <Button onAction="#DeseleccionarTodos" prefWidth="200.0" styleClass="boton-accion" text="Deseleccionar todos" />

                </HBox>

            </VBox>


            <TableView fx:id="tablaClientes">
                <columns>
                    <TableColumn fx:id="colCheckBox" prefWidth="70.0" style="-fx-alignment:CENTER;" text="Seleccion" />
                    <TableColumn fx:id="colNombre" prefWidth="240.0" text="Nombre" />
                    <TableColumn fx:id="colTelefono" prefWidth="120.0" text="Telefono" />
                    <TableColumn fx:id="colFechaCumpleanios" prefWidth="120.0" text="Cumpleaños" />
                </columns>
            </TableView>



            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#Enviar" prefWidth="150" styleClass="boton-accion" text="Enviar promocion" />
                <Button onAction="#cerrarVentana" prefWidth="150" styleClass="boton-accion" text="Cerrar" />
            </HBox>
        </VBox>

        <fx:include source="/fxmlComponentes/Components/TitleBar/modalTittleBar/TittleBarModalComponent.fxml"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"/>
    </children>
</AnchorPane>
