<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500" prefWidth="600" style="-fx-background-color: #080808;" stylesheets="/styles_css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.EditarControllers.EditarClienteController">

    <children>
        <VBox alignment="CENTER" prefHeight="620.0" prefWidth="600" spacing="10" styleClass="secciones">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label styleClass="seccion-titulo" text="Editar Cliente" />

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" prefWidth="150" />
                    <ColumnConstraints prefWidth="300" />
                </columnConstraints>

                <!-- Nombre -->
                <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- Primer Apellido -->
                <Label text="Primer Apellido:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtApellido" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Segundo Apellido -->
                <Label text="Segundo Apellido:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtSegundoApellido" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- Teléfono -->
                <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="txtTelefono" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="3" />


                <!-- Hobbie -->
                <Label text="Hobbie:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtHobbie" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <!-- RFC -->
                <Label text="RFC:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="txtRfc" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <!-- Domicilio -->
                <Label text="Domicilio:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextField fx:id="txtDomicilio" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <!-- Estado -->
                <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <TextField fx:id="txtEstado" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <!-- Ciudad -->
                <Label text="Ciudad:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                <TextField fx:id="txtCiudad" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <!-- Correo -->
                <Label text="Correo:" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                <TextField fx:id="txtCorreo" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="9" />


                <!-- Género -->
                <Label text="Género:" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                <ChoiceBox fx:id="choiceGenero" styleClass="choicebox-mini" GridPane.columnIndex="1" GridPane.rowIndex="10" />

                <!-- Tipo Cliente -->
                <Label text="Tipo Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="11" />
                <ChoiceBox fx:id="choiceTipoCliente" styleClass="choicebox-mini" GridPane.columnIndex="1" GridPane.rowIndex="11" />

                <!-- Fecha Cumpleaños -->
                <Label text="Cumpleaños:" GridPane.columnIndex="0" GridPane.rowIndex="12" />
                <DatePicker fx:id="dateCumpleanos" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="12" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints minHeight="10.0" prefHeight="30.0" />
            </rowConstraints>
            </GridPane>

            <!-- Botones -->
            <HBox alignment="CENTER" spacing="20">
                <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cancelar" />
                <Button fx:id="btnCambiar" onAction="#actualizarCliente" styleClass="boton-accion" text="Actualizar" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
