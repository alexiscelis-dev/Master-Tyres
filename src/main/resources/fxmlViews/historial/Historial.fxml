<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<AnchorPane fx:id="rootPane" prefHeight="600.0" prefWidth="1344.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/PromocionesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.historial.HistorialController">
    <AnchorPane layoutY="110.0" prefHeight="696.0" prefWidth="1186.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
        <VBox>
            <BorderPane prefHeight="600" prefWidth="1186.0">

                <!-- Parte superior: buscador y botones -->
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <TextField fx:id="txtBuscar" maxWidth="800.0" prefHeight="26.0" prefWidth="500.0" promptText="Buscar notas..." styleClass="buscador" HBox.hgrow="ALWAYS" />

                        <HBox alignment="CENTER_RIGHT" spacing="5.0">
                            <Label prefHeight="18.0" prefWidth="79.0" text="Buscar por:" />
                            <ChoiceBox fx:id="atributoBusquedaNota" prefWidth="150.0" styleClass="choicebox-mini2">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Numero de nota" />
                                        <String fx:value="Fecha" />
                                        <String fx:value="Nombre del Cliente" />
                                        <String fx:value="Vehiculo" />
                                        <String fx:value="Status de nota" />
                                        <String fx:value="Fecha de vencimiento" />
                                        <String fx:value="Direccion" />
                                        <String fx:value="Placas de vehiculo" />
                                        <String fx:value="Numero de factura" />
                                        <String fx:value="RFC" />
                                        <String fx:value="Adeudo" />
                                    </FXCollections>
                                </items>
                            </ChoiceBox>
                        </HBox>

                        <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="33.0" styleClass="boton-accion"
                                text="">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                    <image>
                                        <Image url="@/icons/refresh.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <padding>
                            <Insets bottom="20.0" right="20.0" top="20.0"/>
                        </padding>

                    </HBox>
                </top>

                <!-- División principal -->
                <center>
                    <SplitPane dividerPositions="0.40694650817236255" prefHeight="296.0" prefWidth="1278.0" styleClass="seccion">
                        <!-- Panel izquierdo: listado de marcas -->
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #080808; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <TilePane fx:id="contenedorNotas" alignment="CENTER" hgap="10" prefColumns="1" prefTileHeight="40.0" prefTileWidth="300.0" prefWidth="383.0" style="-fx-background-color: #080808; " vgap="10">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>
                            </TilePane>
                        </ScrollPane>

                        <!-- Panel derecho: detalles de la promoción seleccionada -->
                        <VBox fx:id="detallePromocion" alignment="CENTER" prefHeight="483.0" prefWidth="680.0" spacing="10" style="-fx-background-color: rgba(26, 26, 26, 0.85);">

                            <Label alignment="CENTER" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Nota " textAlignment="CENTER" textFill="WHITE" />

                            <GridPane hgap="10" prefHeight="452.0" prefWidth="686.0" vgap="10">

                                <columnConstraints>
                                    <ColumnConstraints minWidth="-Infinity" prefWidth="140.0" />
                                    <ColumnConstraints />
                                </columnConstraints>
                                <padding>
                                    <Insets left="50.0" />
                                </padding>
                            </GridPane>
                            <padding>
                                <Insets left="10.0" />
                            </padding>
                        </VBox>
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>

                    </SplitPane>
                </center>
                <padding>
                    <Insets right="70.0" />
                </padding>

            </BorderPane>

        </VBox>
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
    </AnchorPane>
</AnchorPane>
