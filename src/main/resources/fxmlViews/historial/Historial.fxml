<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="rootPane" prefHeight="600.0" prefWidth="1344.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/PromocionesStyles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.fxControllers.AdministrarMarcasModelosCategorias.AdministarMarcasController">
    <AnchorPane layoutY="110.0" prefHeight="696.0" prefWidth="1186.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
        <VBox>
            <BorderPane prefHeight="600" prefWidth="1186.0">

                <!-- Parte superior: buscador y botones -->
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <TextField fx:id="txtBuscar" promptText="Buscar Marca..." styleClass="buscador" HBox.hgrow="ALWAYS" />
                        <Button fx:id="acrualizar" mnemonicParsing="false" onAction="#Actualizar" prefHeight="25.0" prefWidth="33.0" styleClass="boton-accion" text="">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                    <image>
                                        <Image url="@/icons/refresh.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <padding>
                            <Insets bottom="20.0" right="20.0" top="20.0" />
                        </padding>

                    </HBox>
                </top>

                <!-- División principal -->
                <center>
                    <SplitPane dividerPositions="0.40694650817236255" prefHeight="296.0" prefWidth="1278.0" styleClass="seccion">
                        <!-- Panel izquierdo: listado de marcas -->
                        <ScrollPane fitToWidth="true" style="-fx-background-color: #080808; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <TilePane fx:id="contenedorMarcas" alignment="CENTER" hgap="10" prefColumns="1" prefTileHeight="40.0" prefTileWidth="300.0" prefWidth="383.0" style="-fx-background-color: #080808; " vgap="10">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>
                            </TilePane>
                        </ScrollPane>

                        <!-- Panel derecho: detalles de la promoción seleccionada -->
                        <VBox fx:id="detallePromocion" alignment="CENTER" prefHeight="483.0" prefWidth="680.0" spacing="10" style="-fx-background-color: rgba(26, 26, 26, 0.85);">

                            <Label alignment="CENTER" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Historial" textAlignment="CENTER" textFill="WHITE" />

                            <GridPane hgap="10" prefHeight="452.0" prefWidth="686.0" vgap="10">

                                <columnConstraints>
                                    <ColumnConstraints minWidth="-Infinity" prefWidth="140.0" />
                           <ColumnConstraints />
                                </columnConstraints>
                                <padding>
                                    <Insets left="50.0" />
                                </padding>
                            </GridPane>
                            <padding>
                                <Insets left="10.0" />
                            </padding>
                        </VBox>
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>

                    </SplitPane>
                </center>
                <padding>
                    <Insets right="70.0" />
                </padding>

            </BorderPane>
            <Pagination fx:id="PaginadorMarcas" maxPageIndicatorCount="100" pageCount="1" />
        </VBox>
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
    </AnchorPane>
</AnchorPane>
