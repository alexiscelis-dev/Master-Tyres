<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="600.0" prefWidth="1344.0" style="-fx-background-color: #080808;"
            stylesheets="/styles_css/PromocionesStyles.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.AdministrarMarcasModelosCategorias.AdministarMarcasController">
    <AnchorPane layoutY="110.0" prefHeight="696.0" prefWidth="1186.0" AnchorPane.leftAnchor="50.0"
                AnchorPane.rightAnchor="50.0">
        <VBox>
            <BorderPane prefHeight="600" prefWidth="1186.0">

                <!-- Parte superior: buscador y botones -->
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <TextField fx:id="txtBuscar" promptText="Buscar Marca..." styleClass="buscador"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="acrualizar" mnemonicParsing="false" onAction="#Actualizar" prefHeight="25.0"
                                prefWidth="33.0" styleClass="boton-accion" text="">
                            <graphic>
                                <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                    <image>
                                        <Image url="@/icons/refresh.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <padding>
                            <Insets bottom="20.0" right="20.0" top="20.0"/>
                        </padding>

                    </HBox>
                </top>

                <!-- División principal -->
                <center>
                    <SplitPane dividerPositions="0.40694650817236255" prefHeight="296.0" prefWidth="1278.0"
                               styleClass="seccion">
                        <!-- Panel izquierdo: listado de marcas -->
                        <ScrollPane fitToWidth="true"
                                    style="-fx-background-color: #080808; -fx-border-radius: 10; -fx-background-radius: 10;">
                            <TilePane fx:id="contenedorMarcas" alignment="CENTER" hgap="10" prefColumns="1"
                                      prefTileHeight="40.0" prefTileWidth="300.0" prefWidth="383.0"
                                      style="-fx-background-color: #080808; " vgap="10">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                                </padding>
                            </TilePane>
                        </ScrollPane>

                        <!-- Panel derecho: detalles de la promoción seleccionada -->
                        <VBox fx:id="detallePromocion" alignment="CENTER" prefHeight="483.0" prefWidth="680.0"
                              spacing="10" style="-fx-background-color: rgba(26, 26, 26, 0.85);">

                            <Label alignment="CENTER" style="-fx-font-size: 24px; -fx-font-weight: bold;"
                                   text="Vehiculos de la marca" textAlignment="CENTER" textFill="WHITE"/>

                            <GridPane hgap="10" prefHeight="452.0" prefWidth="686.0" vgap="10">
                                <Label styleClass="titulo" text="Marca:" textFill="WHITE" GridPane.columnIndex="0"
                                       GridPane.rowIndex="0">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                                <Label fx:id="lblNombre" alignment="CENTER_RIGHT" styleClass="texto" textFill="#8eb83d"
                                       wrapText="true" GridPane.columnIndex="1"/>

                                <Label styleClass="titulo" text="Modelos y categorias:" textAlignment="CENTER"
                                       textFill="WHITE" GridPane.columnIndex="0" GridPane.columnSpan="2"
                                       GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                                <TableView fx:id="TablaVehiculoMarca" GridPane.columnSpan="2" GridPane.rowIndex="2"
                                           GridPane.rowSpan="6">
                                    <columns>
                                        <TableColumn fx:id="colMarca" prefWidth="155.0" text="Marca"/>
                                        <TableColumn fx:id="colModelo" prefWidth="155.0" text="Modelo"/>
                                        <TableColumn fx:id="colCategoria" prefWidth="155.0" text="Categoria"/>
                                    </columns>
                                </TableView>

                                <Button fx:id="btnAgregarMarca" onAction="#agregarMarca" prefHeight="54.0"
                                        prefWidth="120.0" styleClass="boton-accion" text="Agregar Marca"
                                        textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2"
                                        GridPane.rowIndex="2" GridPane.rowSpan="2"/>
                                <Button fx:id="btnEditarMarca" disable="true" onAction="#EditarMarca" prefHeight="54.0"
                                        prefWidth="120.0" styleClass="boton-accion" text="Editar Marca"
                                        textAlignment="CENTER" wrapText="true" GridPane.columnIndex="2"
                                        GridPane.rowIndex="4" GridPane.rowSpan="2"/>
                                <Button fx:id="EliminarMarca" onAction="#EliminarMarca" disable="true"
                                        mnemonicParsing="false" prefHeight="54.0" prefWidth="120.0"
                                        styleClass="boton-accion" text="Eliminar Marca" textAlignment="CENTER"
                                        wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="6"
                                        GridPane.rowSpan="2"/>
                                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" GridPane.columnSpan="2"
                                      GridPane.rowIndex="8">
                                    <children>
                                        <Button fx:id="BtnEliminarModelo" onAction="#EliminarModelo" disable="true"
                                                minHeight="54.0" minWidth="120.0" mnemonicParsing="false"
                                                prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion"
                                                text="Eliminar Modelo" textAlignment="CENTER" wrapText="true">
                                            <HBox.margin>
                                                <Insets left="15.0" right="20.0" top="20.0"/>
                                            </HBox.margin>
                                        </Button>
                                        <Button fx:id="BtnAgregarModelo" disable="true" minHeight="54.0"
                                                minWidth="120.0" mnemonicParsing="false" onAction="#AgregarModelo"
                                                prefHeight="54.0" prefWidth="120.0" styleClass="boton-accion"
                                                text="Agregar Modelo" textAlignment="CENTER" wrapText="true">
                                            <HBox.margin>
                                                <Insets left="15.0" right="20.0" top="20.0"/>
                                            </HBox.margin>
                                        </Button>
                                        <Button fx:id="BtnEditarModelo" disable="true" minHeight="54.0" minWidth="120.0"
                                                mnemonicParsing="false" onAction="#EditarModelo" prefHeight="54.0"
                                                prefWidth="120.0" styleClass="boton-accion" text="Editar Modelo"
                                                textAlignment="CENTER" wrapText="true">
                                            <HBox.margin>
                                                <Insets left="15.0" right="20.0" top="20.0"/>
                                            </HBox.margin>
                                        </Button>
                                    </children>
                                </HBox>

                                <columnConstraints>
                                    <ColumnConstraints minWidth="-Infinity" prefWidth="140.0"/>
                                    <ColumnConstraints prefWidth="250.0"/>
                                    <ColumnConstraints halignment="CENTER" minWidth="-Infinity" prefWidth="150.0"/>
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0"/>
                                    <RowConstraints minHeight="30.0" valignment="CENTER"/>
                                    <RowConstraints minHeight="30.0" prefHeight="30.0" valignment="CENTER"/>
                                </rowConstraints>
                                <padding>
                                    <Insets left="50.0"/>
                                </padding>
                            </GridPane>
                            <padding>
                                <Insets left="10.0"/>
                            </padding>
                        </VBox>
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>

                    </SplitPane>
                </center>
                <padding>
                    <Insets right="70.0"/>
                </padding>

            </BorderPane>
            <Pagination fx:id="PaginadorMarcas" maxPageIndicatorCount="100" pageCount="1"/>
        </VBox>
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
    </AnchorPane>
</AnchorPane>
