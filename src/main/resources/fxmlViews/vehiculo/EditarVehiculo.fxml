<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" prefHeight="641.0" prefWidth="602.0" style="-fx-background-color: #080808;"
            stylesheets="/styles-css/ClientesStyles.css" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.controllers.fxControllers.vehiculo.EditarVehiculoController">

    <children>

        <ScrollPane fitToHeight="false" fitToWidth="true" pannable="true" prefHeight="641.0" prefWidth="602.0"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="20.0">


            <VBox alignment="TOP_CENTER" prefHeight="620.0" prefWidth="600" spacing="10" styleClass="secciones">

                <padding>
                    <Insets bottom="20" left="20" right="20" top="20"/>
                </padding>

                <Label styleClass="seccion-titulo" text="Editar Vehículo">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" prefWidth="150"/>
                        <ColumnConstraints prefWidth="300"/>
                    </columnConstraints>

                    <!-- Marca -->
                    <Label styleClass="label-editar" text="Marca:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ChoiceBox fx:id="choiceMarca" styleClass="choicebox-mini2" GridPane.columnIndex="1"
                               GridPane.rowIndex="0"/>

                    <!-- Modelo -->
                    <Label styleClass="label-editar" text="Modelo:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ChoiceBox fx:id="choiceModelo" styleClass="choicebox-mini2" GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>

                    <!-- Categoria -->
                    <Label styleClass="label-editar" text="Categoria:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ChoiceBox fx:id="choiceCategoria" styleClass="choicebox-mini2" GridPane.columnIndex="1"
                               GridPane.rowIndex="2"/>

                    <!-- Año -->
                    <Label styleClass="label-editar" text="Año:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Spinner fx:id="spinnerAnio" editable="true" promptText="Año" styleClass="spinner"
                             GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <!-- Kilometros -->
                    <Label styleClass="label-editar" text="Kilometros:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="txtKilometros" styleClass="buscador" GridPane.columnIndex="1"
                               GridPane.rowIndex="4"/>

                    <!-- Placas -->
                    <Label styleClass="label-editar" text="Placas:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <TextField fx:id="txtPlacas" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <!-- Numero de serire -->
                    <Label styleClass="label-editar" text="Numero de serie:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <TextField fx:id="txtNumSerie" styleClass="buscador" GridPane.columnIndex="1"
                               GridPane.rowIndex="6"/>

                    <!-- Observaciones -->
                    <Label styleClass="label-editar" text="Observaciones:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                    <TextField fx:id="txtObservaciones" styleClass="buscador" GridPane.columnIndex="1"
                               GridPane.rowIndex="7"/>

                    <!-- Ultimo servicio -->
                    <Label styleClass="label-editar" text="Ultimo servicio:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
                    <DatePicker fx:id="dateUltimoServicio" editable="false" styleClass="date-picker"
                                GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                    <!-- Color -->
                    <Label styleClass="label-editar" text="Color:" GridPane.columnIndex="0" GridPane.rowIndex="9"/>
                    <TextField fx:id="txtColor" styleClass="buscador" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>

                </GridPane>

                <!-- Botones -->
                <HBox alignment="CENTER" spacing="20">
                    <Button fx:id="btnCambiar" styleClass="boton-accion" text="Actualizar"/>
                    <Button onAction="#cerrarVentana" styleClass="boton-accion" text="Cancelar"/>
                </HBox>
            </VBox>


        </ScrollPane>

        <fx:include source="/fxmlComponentes/Components/TitleBar/modalTittleBar/TittleBarModalComponent.fxml"
                    AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"/>

    </children>
</AnchorPane>
