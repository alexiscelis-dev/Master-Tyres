<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="rootPane" prefWidth="600" prefHeight="500" xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mastertyres.fxControllers.EditarControllers.EditarVehiculoController"
            style="-fx-background-color: #080808;"
            stylesheets="/styles_css/ClientesStyles.css">

    <children>
        <VBox spacing="10" alignment="CENTER" prefWidth="600" prefHeight="500" styleClass="secciones">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Editar Vehiculo"  styleClass="seccion-titulo" />

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" prefWidth="150"/>
                    <ColumnConstraints prefWidth="300"/>
                </columnConstraints>

                <!-- Marca -->
                <Label text="Marca:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ChoiceBox fx:id="choiceMarca" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="choicebox-mini2" />

                <!-- Modelo -->
                <Label text="Modelo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ChoiceBox fx:id="choiceModelo" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="choicebox-mini2" />

                <!-- Categoria -->
                <Label text="Categoria:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ChoiceBox fx:id="choiceCategoria" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="choicebox-mini2" />

                <!-- Año -->
                <Label text="Año:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Spinner fx:id="spinnerAnio" editable="true" promptText="Año" styleClass="spinner" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <!-- Kilometros -->
                <Label text="Kilometros:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtKilometros" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="buscador" />

                <!-- Placas -->
                <Label text="Placas:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPlacas" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="buscador" />

                <!-- Numero de serire -->
                <Label text="Numero de serie:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNumSerie" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="buscador" />

                <!-- Observaciones -->
                <Label text="Observaciones:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <TextField fx:id="txtObservaciones" GridPane.rowIndex="7" GridPane.columnIndex="1" styleClass="buscador" />

                <!-- Ultimo servicio -->
                <Label text="Ultimo servicio:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dateUltimoServicio" editable="false" GridPane.rowIndex="8" GridPane.columnIndex="1" styleClass="date-picker"  />

                <!-- Color -->
                <Label text="Color:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                <TextField fx:id="txtColor" GridPane.rowIndex="9" GridPane.columnIndex="1" styleClass="buscador" />

            </GridPane>

            <!-- Botones -->
            <HBox spacing="20" alignment="CENTER">
                <Button text="Actualizar" fx:id="btnCambiar"  styleClass="boton-accion" />
                <Button text="Cancelar" onAction="#cerrarVentana" styleClass="boton-accion" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
