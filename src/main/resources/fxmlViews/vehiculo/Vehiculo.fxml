<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="rootPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1344.0" style="-fx-background-color: #080808;" stylesheets="/styles_css/PaginaPrincipal.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mastertyres.controllers.fxControllers.vehiculo.VehiculoController">

   <children>

      <AnchorPane layoutX="14.0" layoutY="121.0" prefHeight="479.0" prefWidth="1152.0" style="-fx-background-color: #080808;" styleClass="clientes-panel" stylesheets="/styles_css/ClientesStyles.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="178.0" AnchorPane.topAnchor="121.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">

         <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">

            <!-- Zona superior: Búsqueda y botón agregar -->
            <HBox fx:id="limpiarChoiceBox" alignment="CENTER_LEFT" spacing="10.0">
               <HBox alignment="CENTER_LEFT" spacing="5.0" fx:id="contenedorBusqueda">
                  <TextField fx:id="buscarVehiculoBuscador" prefHeight="26.0" prefWidth="300.0" promptText="Buscar Vehiculo..." styleClass="buscador" />

                  <DatePicker fx:id="dpVehiculoInicio" prefHeight="26.0" prefWidth="150.0" promptText="Fecha" visible="false" managed="false" />

                  <CheckBox fx:id="chkRangoFechas" text="Rango" visible="false" managed="false" />

                  <Label fx:id="lblHasta" text="a" visible="false" managed="false" />

                  <DatePicker fx:id="dpVehiculoFin" prefHeight="26.0" prefWidth="150.0" promptText="Fecha fin" visible="false" managed="false" />

                  <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#accionBuscarVehiculo" prefHeight="26.0" prefWidth="40.0" styleClass="boton-accion">
                     <graphic>
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                           <image>
                              <Image url="@/icons/lupa.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </HBox>

               <HBox alignment="CENTER_RIGHT" spacing="5.0">
                  <Label prefWidth="79.0" text="Buscar por: " />
                  <ChoiceBox fx:id="atributoBusquedaVehiculos" prefWidth="150.0" styleClass="choicebox-mini2">
                     <items>
                        <FXCollections fx:factory="observableArrayList">
                           <String fx:value="Propietario" />
                           <String fx:value="Marca" />
                           <String fx:value="Modelo" />
                           <String fx:value="Categoria" />
                           <String fx:value="Color" />
                           <String fx:value="Año" />
                           <String fx:value="Placas" />
                           <String fx:value="Numero Serie" />
                           <String fx:value="Kilometraje" />
                           <String fx:value="Ultimo Servicio" />
                           <String fx:value="Fecha Registro" />
                        </FXCollections>
                     </items>
                  </ChoiceBox>
               </HBox>

               <Pane style="-fx-background-color: #080808;" HBox.hgrow="ALWAYS">
                  <children>
                     <Button fx:id="btnModificarMarcaModeloCategoria" layoutX="1.0" layoutY="1.0" onAction="#ModificarMarcaModeloCategoria" prefHeight="25.0" prefWidth="181.0" styleClass="boton-accion" text="Administrar Marcas" />
                     <Button fx:id="btnAgregarVehiculo" layoutX="195.0" layoutY="1.0" onAction="#agregarVehiculo" prefHeight="25.0" prefWidth="150.0" styleClass="boton-accion" text="Agregar Vehiculo" />
                     <Button fx:id="btnRefrescar" layoutX="354.0" layoutY="1.0" mnemonicParsing="false" onAction="#actualizarTabla" prefHeight="25.0" prefWidth="33.0" styleClass="boton-accion">
                        <graphic>
                           <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                              <image>
                                 <Image url="@/icons/refresh.png" />
                              </image>
                           </ImageView>
                        </graphic>
                     </Button>
                  </children>
               </Pane>
            </HBox>

            <!-- Tabla de clientes -->
            <TableView fx:id="tablaVehiculos" prefHeight="500.0" style="-fx-background-color: #1A1A1A;">
               <columns>
                  <TableColumn fx:id="colCliente" prefWidth="150" text="Propietario" />
                  <TableColumn fx:id="colMarca" prefWidth="150" text="Marca" />
                  <TableColumn fx:id="colModelo" prefWidth="150" text="Modelo" />
                  <TableColumn fx:id="colCategoria" prefWidth="150" text="Categoria" />
                  <TableColumn fx:id="colColor" prefWidth="150" text="Color" />
                  <TableColumn fx:id="colAnio" prefWidth="150" text="Año" />
                  <TableColumn fx:id="colPlacas" prefWidth="150" text="Placas" />
                  <TableColumn fx:id="colNumeroSerie" prefWidth="150" text="Numero Serie" />
                  <TableColumn fx:id="colKilometraje" prefWidth="150" text="Kilometraje" />
                  <TableColumn fx:id="colObservaciones" prefWidth="80" text="Observaciones" />
                  <TableColumn fx:id="colUltimoServicio" prefWidth="150" text="Ultimo Servicio" />
                  <TableColumn fx:id="colFechaRegistro" prefWidth="150" text="Fecha Registro" />

               </columns>
            </TableView>
            <Label fx:id="statusLabel" prefHeight="60.0" prefWidth="220.0" text="Label" textFill="WHITE" visible="false">
               <VBox.margin>
                  <Insets left="480.0" />
               </VBox.margin>
               <font>
                  <Font name="Roboto Bold" size="12.0" />
               </font>
            </Label>


            <Pagination fx:id="paginadorVehiculos" maxPageIndicatorCount="100" pageCount="1" />

         </VBox>


      </AnchorPane>
   </children>
</AnchorPane>
